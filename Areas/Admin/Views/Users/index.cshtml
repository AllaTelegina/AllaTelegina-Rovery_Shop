@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Админ-панель — Пользователи</title>
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>

  <body class="bg-gray-100 flex">

    <main class="flex-1 bg-gray-100 min-h-screen" x-data="usersAdmin()">

    <div class="p-6 min-h-screen">
      <!-- Заголовок и кнопка -->
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">
        <h1 class="text-3xl font-bold flex items-center gap-2 text-gray-800">👥 Пользователи</h1>
        
        <div class="flex gap-2 w-full md:w-auto">
      
             <!-- Фильтры -->
      <div class="flex flex-wrap items-center gap-3">
        <div class="flex-1">
          <input
            type="text"
            placeholder="🔍 Поиск по имени, email или телефону"
            class="w-full md:w-72 border border-gray-300 rounded-lg px-3 py-2 focus:ring-teal-200 focus:border-teal-500 outline-none"
          />
        </div>
        <select class="border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-teal-600">
          <option>Все статусы</option>
          <option>Активен</option>
          <option>Заблокирован</option>
        </select>
        <select class="border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-teal-600">
          <option>Все подписки</option>
          <option>Подписан</option>
          <option>Не подписан</option>
        </select>
      </div>

        <button
          @@click="openModal = true; mode = 'edit'"
          class="bg-teal-600 text-white px-4 py-2 rounded-lg hover:bg-teal-500 transition"        >
          <span>＋</span> Добавить пользователя
        </button>
        </div>
      </div>

      

      <!-- Таблица -->
      <div class="bg-white shadow-md rounded-xl overflow-hidden">
        <table class="w-full border-collapse text-sm text-gray-700">
          <thead class="bg-gray-100 text-gray-700 text-left">
            <tr>
              <th class="py-3 px-4">ID</th>
              <th class="py-3 px-4">Имя</th>
              <th class="py-3 px-4">Email</th>
              <th class="py-3 px-4">Телефон</th>
              <th class="py-3 px-4">Город</th>
              <th class="py-3 px-4">Подписка</th>
              <th class="py-3 px-4">Статус</th>
              <th class="py-3 px-4">Дата регистрации</th>
              <th class="py-3 px-4">Дата последнего входа</th>
              <th class="py-3 px-4 text-center">Действия</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-t hover:bg-gray-50">
              <td class="py-3 px-4">1</td>
              <td class="py-3 px-4 font-medium">Иван Петров</td>
              <td class="py-3 px-4">ivan@example.com</td>
              <td class="py-3 px-4">+7 (999) 555-44-33</td>
              <td class="py-3 px-4">Москва</td>
              <td class="py-3 px-4 text-teal-600 font-medium">Да</td>
              <td class="py-3 px-4">
                <span class="bg-emerald-100 text-etal-600 px-2 py-1 rounded text-xs font-medium">Активен</span>
              </td>
              <td class="py-3 px-4 text-gray-500 text-sm">01.10.2025</td>
              <td class="py-3 px-4 text-gray-500 text-sm">05.11.2025</td>
              <td class="py-3 px-4 text-center">
                <div class="flex justify-center gap-3">
                  <button
                    @@click="openModal = true; mode = 'view'"
                    class="text-teal-600 hover:text-teal-500"
                    title="Просмотр"
                  >
                    👁️
                  </button>
                  <button
                    @@click="openModal = true; mode = 'edit'"
                    class="text-etal-600 hover:text-etal-700"
                    title="Редактировать"
                  >
                    ✏️
                  </button>
                  <button class="text-red-500 hover:text-red-700" title="Удалить">🗑️</button>
                </div>
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Пагинация -->
      <div class="flex justify-between items-center mt-4 text-sm text-gray-600">
        <p>Страница 1 из 10</p>
        <div class="flex items-center gap-2">
          <button class="px-3 py-1 border border-gray-300 rounded hover:bg-gray-100">←</button>
          <button class="px-3 py-1 border border-teal-500 bg-teal-600 text-white rounded">1</button>
          <button class="px-3 py-1 border border-gray-300 rounded hover:bg-gray-100">2</button>
          <button class="px-3 py-1 border border-gray-300 rounded hover:bg-gray-100">→</button>
        </div>
      </div>
    </div>

    <!-- Модалка -->
    <div
      x-show="openModal"
      x-transition
      class="fixed inset-0 bg-black/40 flex items-center justify-center z-50"
    >
      <div
        @@click.outside="openModal = false"
        class="bg-white rounded-2xl shadow-lg w-full max-w-lg p-6 relative"
      >
        <button
          @@click="openModal = false"
          class="absolute top-3 right-3 text-red-700 hover:text-red-500"
        >
          ✖
        </button>

        <div class="flex items-center justify-between mb-4">
          <h3 class="text-xl font-semibold" x-text="mode === 'view' ? 'Просмотр пользователя' : 'Редактировать пользователя'"></h3>
          <template x-if="mode === 'view'">
            <button
              @@click="mode = 'edit'"
              class="text-sm px-3 py-1 bg-teal-600 text-white rounded-lg hover:bg-etal-500"
            >
              ✏️ Редактировать
            </button>
          </template>
        </div>

        <form class="space-y-4">
          <div>
            <label class="block text-sm font-medium mb-1">Имя</label>
            <input
              type="text"
              class="w-full border rounded-lg px-3 py-2 focus:ring-2 focus:ring-teal-600 outline-none"
              :disabled="mode === 'view'"
              value="Иван Петров"
            />
          </div>

          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium mb-1">Email</label>
              <input
                type="email"
                class="w-full border rounded-lg px-3 py-2 focus:ring-2 focus:ring-teal-600 outline-none"
                :disabled="mode === 'view'"
                value="ivan@example.com"
              />
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Телефон</label>
              <input
                type="tel"
                class="w-full border rounded-lg px-3 py-2 focus:ring-2 focus:ring-teal-600 outline-none"
                :disabled="mode === 'view'"
                value="+7 (999) 555-44-33"
              />
            </div>
          </div>

          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium mb-1">Страна</label>
              <input
                type="text"
                class="w-full border rounded-lg px-3 py-2 focus:ring-2 focus:ring-teal-600 outline-none"
                :disabled="mode === 'view'"
                value="Россия"
              />
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Город</label>
              <input
                type="text"
                class="w-full border rounded-lg px-3 py-2 focus:ring-2 focus:ring-teal-600outline-none"
                :disabled="mode === 'view'"
                value="Москва"
              />
            </div>
          </div>

          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium mb-1">Дата рождения</label>
              <input
                type="date"
                class="w-full border rounded-lg px-3 py-2 focus:ring-2 focus:ring-teal-600 outline-none"
                :disabled="mode === 'view'"
                value="1995-04-12"
              />
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Статус</label>
              <select
                class="w-full border rounded-lg px-3 py-2 focus:ring-2 focus:ring-teal-600 outline-none"
                :disabled="mode === 'view'"
              >
                <option selected>Активен</option>
                <option>Заблокирован</option>
              </select>
            </div>
          </div>

          <div class="flex items-center gap-2">
            <input type="checkbox" id="subscribe" checked :disabled="mode === 'view'" />
            <label for="subscribe" class="text-sm text-gray-700">
              Подписан на рассылку
            </label>
          </div>

          <div class="flex justify-end mt-5 gap-3">
            <button
              type="button"
              @@click="openModal = false"
              class="px-4 py-2 rounded-lg border border-gray-300 hover:bg-gray-100"
            >
              Закрыть
            </button>
            <template x-if="mode === 'edit'">
              <button
                type="submit"
                class="px-4 py-2 rounded-lg bg-teal-600 text-white hover:bg-teal-500"
              >
                💾 Сохранить
              </button>
            </template>
          </div>
        </form>
      </div>
    </div>
</main>
  <script>
  function userAdmin() {
    return {
      users: [
        { id: 1, name: 'Иван Иванов', email: 'ivan@mail.ru', phone: '+7 (900) 111-22-33', role: 'Admin', status: 'Активен', registered: '01.11.2025', last_login: '05.11.2025' },
        { id: 2, name: 'Мария Смирнова', email: 'maria@gmail.com', phone: '+7 (900) 222-33-44', role: 'User', status: 'Заблокирован', registered: '02.11.2025', last_login: '03.11.2025' },
      ],
      form: { name: '', email: '', phone: '', role: 'User', status: 'Активен', password: '' },
      showModal: false,
      editId: null,
      searchQuery: '',
      roleFilter: '',
      statusFilter: '',
      currentPage: 1,
      perPage: 5,

      get filteredUsers() {
        let list = [...this.users];
        if (this.searchQuery) list = list.filter(u =>
          u.name.toLowerCase().includes(this.searchQuery.toLowerCase()) ||
          u.email.toLowerCase().includes(this.searchQuery.toLowerCase())
        );
        if (this.roleFilter) list = list.filter(u => u.role === this.roleFilter);
        if (this.statusFilter) list = list.filter(u => u.status === this.statusFilter);
        const start = (this.currentPage - 1) * this.perPage;
        return list.slice(start, start + this.perPage);
      },

      get paginatedUsers() { return this.filteredUsers; },
      get totalPages() { return Math.ceil(this.users.length / this.perPage); },

      openModal() { this.showModal = true; this.editId = null; this.form = { name: '', email: '', phone: '', role: 'User', status: 'Активен', password: '' }; },
      closeModal() { this.showModal = false; },

      saveUser() {
        if (this.editId) {
          const index = this.users.findIndex(u => u.id === this.editId);
          this.users[index] = { ...this.form, id: this.editId };
        } else {
          const newId = this.users.length ? Math.max(...this.users.map(u => u.id)) + 1 : 1;
          this.users.push({ ...this.form, id: newId });
        }
        this.closeModal();
      },

      editUser(user) { this.editId = user.id; this.form = JSON.parse(JSON.stringify(user)); this.showModal = true; },
      deleteUser(id) { this.users = this.users.filter(u => u.id !== id); },

      prevPage() { if (this.currentPage > 1) this.currentPage--; },
      nextPage() { if (this.currentPage < this.totalPages) this.currentPage++; }
    };
  }
  </script>

</body>
</>
