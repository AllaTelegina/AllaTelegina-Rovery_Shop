@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Пользователи";
}

<div x-data="{ filter: '', selected: null }">

<h2 class="text-2xl font-bold mb-4">Пользователи</h2>

<div class="flex mb-4 space-x-2">
    <input type="text" placeholder="Поиск по имени или email..." x-model="filter" class="p-2 border rounded flex-1" />
    <select class="p-2 border rounded">
        <option>Все роли</option>
        <option>Админ</option>
        <option>Пользователь</option>
    </select>
</div>

<table class="w-full bg-white rounded shadow overflow-hidden">
    <thead class="bg-gray-100">
        <tr>
            <th class="p-2">ID</th>
            <th class="p-2">Имя</th>
            <th class="p-2">Email</th>
            <th class="p-2">Роль</th>
            <th class="p-2">Действия</th>
        </tr>
    </thead>
    <tbody>
        <tr class="border-b">
            <td class="p-2">U101</td>
            <td class="p-2">Иван Иванов</td>
            <td class="p-2">ivan@mail.ru</td>
            <td class="p-2">Пользователь</td>
            <td class="p-2">
                <button @click="selected = { id: 'U101', name: 'Иван Иванов', email: 'ivan@mail.ru', role: 'Пользователь' }" class="text-blue-600 hover:underline">Просмотр</button>
            </td>
        </tr>
    </tbody>
</table>

<!-- Модальное окно просмотра пользователя -->
<div x-show="selected" class="fixed inset-0 flex items-center justify-center bg-black bg-opacity-50 z-50">
    <div class="bg-white rounded shadow-lg p-6 w-1/2" @click.away="selected = null">
        <h3 class="text-xl font-semibold mb-4" x-text="'Пользователь: ' + selected.name"></h3>
        <p><strong>Email:</strong> <span x-text="selected.email"></span></p>
        <p><strong>Роль:</strong> <span x-text="selected.role"></span></p>
        <div class="flex justify-end mt-4 space-x-2">
            <button @click="selected = null" class="px-4 py-2 rounded border">Закрыть</button>
            <button @click="selected.role = 'Админ'; selected = null" class="px-4 py-2 rounded bg-green-600 text-white hover:bg-green-700">Сделать админом</button>
            <button @click="selected.role = 'Пользователь'; selected = null" class="px-4 py-2 rounded bg-blue-600 text-white hover:bg-blue-700">Сделать пользователем</button>
        </div>
    </div>
</div>

</div>
