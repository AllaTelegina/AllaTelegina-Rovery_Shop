@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Комментарии";
}

<div x-data="{ filter: '', selected: null }">

<h2 class="text-2xl font-bold mb-4">Комментарии</h2>

<div class="flex mb-4 space-x-2">
    <input type="text" placeholder="Поиск по пользователю..." x-model="filter" class="p-2 border rounded flex-1" />
    <select class="p-2 border rounded">
        <option>Все статусы</option>
        <option>Ожидает</option>
        <option>Одобрено</option>
        <option>Отклонено</option>
    </select>
</div>

<table class="w-full bg-white rounded shadow overflow-hidden">
    <thead class="bg-gray-100">
        <tr>
            <th class="p-2">ID</th>
            <th class="p-2">Пользователь</th>
            <th class="p-2">Комментарий</th>
            <th class="p-2">Статус</th>
            <th class="p-2">Действия</th>
        </tr>
    </thead>
    <tbody>
        <tr class="border-b">
            <td class="p-2">1</td>
            <td class="p-2">Петр Петров</td>
            <td class="p-2">Отличный велосипед!</td>
            <td class="p-2 text-red-600">Ожидает</td>
            <td class="p-2">
                <button @click="selected = { id: 1, user: 'Петр Петров', message: 'Отличный велосипед!', status: 'Ожидает' }" class="text-blue-600 hover:underline">Просмотр</button>
            </td>
        </tr>
    </tbody>
</table>

<!-- Модальное окно -->
<div x-show="selected" class="fixed inset-0 flex items-center justify-center bg-black bg-opacity-50 z-50">
    <div class="bg-white rounded shadow-lg p-6 w-1/2" @click.away="selected = null">
        <h3 class="text-xl font-semibold mb-4" x-text="'Комментарий #' + selected.id"></h3>
        <p><strong>Пользователь:</strong> <span x-text="selected.user"></span></p>
        <p><strong>Текст:</strong> <span x-text="selected.message"></span></p>
        <p><strong>Статус:</strong> <span x-text="selected.status"></span></p>
        <div class="flex justify-end mt-4 space-x-2">
            <button @click="selected = null" class="px-4 py-2 rounded border">Закрыть</button>
            <button @click="selected.status = 'Одобрено'; selected = null" class="px-4 py-2 rounded bg-green-600 text-white hover:bg-green-700">Одобрить</button>
            <button @click="selected.status = 'Отклонено'; selected = null" class="px-4 py-2 rounded bg-red-600 text-white hover:bg-red-700">Отклонить</button>
        </div>
    </div>
</div>

</div>
