@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Обратная связь";
}

<div x-data="{ filter: '', selected: null, messages: [
    { id: 1, name: 'Иван Иванов', email: 'ivan@mail.ru', subject: 'Вопрос о доставке', message: 'Когда придёт мой заказ?', read: false },
    { id: 2, name: 'Петр Петров', email: 'petr@mail.ru', subject: 'Возврат товара', message: 'Как вернуть товар?', read: true }
] }">

<h2 class="text-2xl font-bold mb-4">Сообщения обратной связи</h2>

<div class="flex mb-4 space-x-2">
    <input type="text" placeholder="Поиск по имени или email..." x-model="filter" class="p-2 border rounded flex-1" />
</div>

<table class="w-full bg-white rounded shadow overflow-hidden">
    <thead class="bg-gray-100">
        <tr>
            <th class="p-2">ID</th>
            <th class="p-2">Имя</th>
            <th class="p-2">Email</th>
            <th class="p-2">Тема</th>
            <th class="p-2">Статус</th>
            <th class="p-2">Действия</th>
        </tr>
    </thead>
    <tbody>
        <template x-for="msg in messages.filter(m => m.name.includes(filter) || m.email.includes(filter))" :key="msg.id">
            <tr class="border-b">
                <td class="p-2" x-text="msg.id"></td>
                <td class="p-2" x-text="msg.name"></td>
                <td class="p-2" x-text="msg.email"></td>
                <td class="p-2" x-text="msg.subject"></td>
                <td class="p-2">
                    <span x-text="msg.read ? 'Прочитано' : 'Непрочитано'" :class="msg.read ? 'text-green-600' : 'text-red-600'"></span>
                </td>
                <td class="p-2">
                    <button @click="selected = msg" class="text-blue-600 hover:underline">Просмотр</button>
                </td>
            </tr>
        </template>
    </tbody>
</table>

<!-- Модальное окно просмотра -->
<div x-show="selected" class="fixed inset-0 flex items-center justify-center bg-black bg-opacity-50 z-50">
    <div class="bg-white rounded shadow-lg p-6 w-1/2" @click.away="selected = null">
        <h3 class="text-xl font-semibold mb-4" x-text="selected ? selected.subject : ''"></h3>
        <p class="mb-2"><strong>От:</strong> <span x-text="selected ? selected.name : ''"></span> (<span x-text="selected ? selected.email : ''"></span>)</p>
        <p class="mb-4" x-text="selected ? selected.message : ''"></p>
        <div class="flex justify-end space-x-2">
            <button @click="selected = null" class="px-4 py-2 rounded border">Закрыть</button>
            <button @click="selected.read = true; selected = null" class="px-4 py-2 rounded bg-green-600 text-white hover:bg-green-700">Отметить как прочитано</button>
        </div>
    </div>
</div>

</div>
