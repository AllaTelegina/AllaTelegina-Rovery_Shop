@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Товары";
}

<div x-data="{ open: false, filter: '', selected: null, messages: [] }">

<div class="flex justify-between items-center mb-4">
    <h2 class="text-2xl font-bold">Список товаров</h2>
    <button @click="open = true" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">Добавить товар</button>
</div>

<div class="flex mb-4 space-x-2">
    <input type="text" placeholder="Поиск товара..." x-model="filter" class="p-2 border rounded flex-1" />
    <select class="p-2 border rounded">
        <option>Все категории</option>
        <option>Велосипеды</option>
        <option>Самокаты</option>
    </select>
</div>

<table class="w-full bg-white rounded shadow overflow-hidden">
    <thead class="bg-gray-100">
        <tr>
            <th class="p-2 text-left">ID</th>
            <th class="p-2 text-left">Название</th>
            <th class="p-2 text-left">Категория</th>
            <th class="p-2 text-left">Цена</th>
            <th class="p-2 text-left">Действия</th>
        </tr>
    </thead>
    <tbody>
        <tr class="border-b" x-show="true">
            <td class="p-2">1</td>
            <td class="p-2">Велосипед</td>
            <td class="p-2">Велосипеды</td>
            <td class="p-2">12 000 ₽</td>
            <td class="p-2">
                <button class="text-blue-600 hover:underline">Редактировать</button> |
                <button class="text-red-600 hover:underline">Удалить</button>
            </td>
        </tr>
    </tbody>
</table>

<!-- Модальное окно добавления -->
<div x-show="open" class="fixed inset-0 flex items-center justify-center bg-black bg-opacity-50 z-50">
    <div class="bg-white rounded shadow-lg p-6 w-1/2" @click.away="open = false">
        <h3 class="text-xl font-semibold mb-4">Добавить новый товар</h3>
        <form class="space-y-4">
            <input type="text" placeholder="Название товара" class="w-full p-2 border rounded" />
            <input type="number" placeholder="Цена" class="w-full p-2 border rounded" />
            <select class="w-full p-2 border rounded">
                <option>Велосипеды</option>
                <option>Самокаты</option>
            </select>
            <div class="flex justify-end space-x-2">
                <button type="button" @click="open = false" class="px-4 py-2 rounded border">Отмена</button>
                <button type="submit" class="px-4 py-2 rounded bg-blue-600 text-white hover:bg-blue-700">Сохранить</button>
            </div>
        </form>
    </div>
</div>

</div>
