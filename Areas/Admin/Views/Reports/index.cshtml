@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Отчёты";
}

<div x-data="{ filter: '', selected: null }">

<h2 class="text-2xl font-bold mb-4">Отчёты</h2>

<div class="flex mb-4 space-x-2">
    <input type="text" placeholder="Поиск по названию отчёта..." x-model="filter" class="p-2 border rounded flex-1" />
    <select class="p-2 border rounded">
        <option>Все типы</option>
        <option>Продажи</option>
        <option>Пользователи</option>
        <option>Отзывы</option>
    </select>
</div>

<table class="w-full bg-white rounded shadow overflow-hidden">
    <thead class="bg-gray-100">
        <tr>
            <th class="p-2">ID</th>
            <th class="p-2">Название</th>
            <th class="p-2">Дата</th>
            <th class="p-2">Действия</th>
        </tr>
    </thead>
    <tbody>
        <tr class="border-b">
            <td class="p-2">R101</td>
            <td class="p-2">Отчёт по продажам</td>
            <td class="p-2">01.10.2025</td>
            <td class="p-2">
                <button @click="selected = { title: 'Отчёт по продажам', content: 'Содержимое отчёта...' }" class="text-blue-600 hover:underline">Просмотр</button>
            </td>
        </tr>
    </tbody>
</table>

<!-- Модальное окно -->
<div x-show="selected" class="fixed inset-0 flex items-center justify-center bg-black bg-opacity-50 z-50">
    <div class="bg-white rounded shadow-lg p-6 w-1/2" @click.away="selected = null">
        <h3 class="text-xl font-semibold mb-4" x-text="selected.title"></h3>
        <p x-text="selected.content"></p>
        <div class="flex justify-end mt-4">
            <button @click="selected = null" class="px-4 py-2 rounded border">Закрыть</button>
        </div>
    </div>
</div>

</div>
