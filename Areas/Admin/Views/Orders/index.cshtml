@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Заказы";
}

<div x-data="{ filter: '', selected: null }">

<h2 class="text-2xl font-bold mb-4">Список заказов</h2>

<!-- Фильтр по статусу и поиск по клиенту -->
<div class="flex mb-4 space-x-2">
    <input type="text" placeholder="Поиск по клиенту..." x-model="filter" class="p-2 border rounded flex-1" />
    <select class="p-2 border rounded">
        <option>Все статусы</option>
        <option>Новый</option>
        <option>В обработке</option>
        <option>Доставлен</option>
    </select>
</div>

<table class="w-full bg-white rounded shadow overflow-hidden">
    <thead class="bg-gray-100">
        <tr>
            <th class="p-2">ID</th>
            <th class="p-2">Клиент</th>
            <th class="p-2">Сумма</th>
            <th class="p-2">Статус</th>
            <th class="p-2">Действия</th>
        </tr>
    </thead>
    <tbody>
        <tr class="border-b">
            <td class="p-2">101</td>
            <td class="p-2">Иван Иванов</td>
            <td class="p-2">12 000 ₽</td>
            <td class="p-2 text-red-600">Новый</td>
            <td class="p-2">
                <button @click="selected = { id: 101, client: 'Иван Иванов', sum: '12 000 ₽', status: 'Новый', items: ['Велосипед'] }" class="text-blue-600 hover:underline">Просмотр</button>
            </td>
        </tr>
    </tbody>
</table>

<!-- Модальное окно просмотра заказа -->
<div x-show="selected" class="fixed inset-0 flex items-center justify-center bg-black bg-opacity-50 z-50">
    <div class="bg-white rounded shadow-lg p-6 w-1/2" @click.away="selected = null">
        <h3 class="text-xl font-semibold mb-4">Заказ #<span x-text="selected.id"></span></h3>
        <p class="mb-2"><strong>Клиент:</strong> <span x-text="selected.client"></span></p>
        <p class="mb-2"><strong>Сумма:</strong> <span x-text="selected.sum"></span></p>
        <p class="mb-2"><strong>Статус:</strong> <span x-text="selected.status"></span></p>
        <p class="mb-4"><strong>Товары:</strong> <span x-text="selected.items.join(', ')"></span></p>
        <div class="flex justify-end space-x-2">
            <button @click="selected = null" class="px-4 py-2 rounded border">Закрыть</button>
        </div>
    </div>
</div>

</div>
