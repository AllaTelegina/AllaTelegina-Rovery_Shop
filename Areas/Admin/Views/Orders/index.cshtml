@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AdminPanel — Заказы</title>
   <link href="output.css" rel="stylesheet">
      <script src="https://cdn.tailwindcss.com"></script>

      <!-- Alpine.js (defer - скрипт ждёт загрузки DOM) -->
      <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>

      <!-- Flowbite JS (версия 2.3.0) -->
      <script defer src="https://unpkg.com/flowbite@2.3.0/dist/flowbite.min.js"></script>

      <!-- основной JS -->

      <script type="module" defer src="/dist/main.js"></script>
</head>

<body class="bg-gray-100 flex">

<main class="flex-1 p-8 bg-gray-100 min-h-screen" x-data="ordersAdmin()">

  <!-- Заголовок -->
  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">
    <h1 class="text-3xl font-bold text-gray-800">📦 Управление заказами</h1>
    <div class="flex gap-2 w-full md:w-auto">
    <!-- Поиск -->
    <button @@click="openModal"
            class="bg-teal-600 text-white px-5 py-2 rounded-lg hover:bg-teal-500 transition">
      <span>＋</span> Добавить заказ
    </button>
  </div>
  </div>

  <!-- Поиск -->
  <div class="flex items-center mb-6">
    <input type="text" placeholder="🔍 Поиск по названию или SKU..."
     @@input="page = 1"      
     x-model="searchQuery"
     class="w-full md:w-1/3 border border-gray-300 rounded-lg px-4 py-2 focus:border-teal-500 focus:ring focus:ring-teal-200 outline-none">
  </div>

  <!-- Таблица заказов -->
  <div class="overflow-x-auto bg-white rounded-lg shadow-md">
    <table class="min-w-full text-sm text-left">
      <thead class="bg-gray-200 text-gray-700 uppercase text-xs">
        <tr>
          <th class="px-4 py-3 cursor-pointer" @@click="sort('id')">ID</th>
          <th class="px-4 py-3 cursor-pointer" @@click="sort('order_date')">Дата заказа</th>
          <th class="px-4 py-3">SKU</th>
          <th class="px-4 py-3">Название</th>
          <th class="px-4 py-3">Цвет</th>
          <th class="px-4 py-3">Кол-во</th>
          <th class="px-4 py-3">Цена</th>
          <th class="px-4 py-3">Доставка</th>
          <th class="px-4 py-3">Сборка</th>
          <th class="px-4 py-3">Оплата</th>
          <th class="px-4 py-3 cursor-pointer" @@click="sort('status')">Статус</th>
          <th class="px-4 py-3">Дата доставки</th>
          <th class="px-4 py-3 text-right">Действия</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <template x-for="order in filteredOrders" :key="order.id">
          <tr>
            <td class="px-4 py-3 text-gray-600" x-text="order.id"></td>
            <td class="px-4 py-3 text-gray-600" x-text="order.order_date"></td>
            <td class="px-4 py-3 text-gray-600" x-text="order.sku"></td>
            <td class="px-4 py-3 font-medium text-gray-800" x-text="order.title"></td>
            <td class="px-4 py-3 text-gray-600" x-text="order.color"></td>
            <td class="px-4 py-3 text-gray-600" x-text="order.quantity"></td>
            <td class="px-4 py-3 text-gray-600" x-text="order.price + ' ₽'"></td>
            <td class="px-4 py-3 text-gray-600" x-text="order.delivery_type"></td>
            <td class="px-4 py-3" x-text="order.assembly ? 'Да' : 'Нет'"></td>
            <td class="px-4 py-3" :class="order.paid ? 'text-green-600' : 'text-red-600'" x-text="order.paid ? 'Оплачено' : 'Не оплачено'"></td>
            <td class="px-4 py-3 text-gray-600" x-text="order.status"></td>
            <td class="px-4 py-3 text-gray-600" x-text="order.delivery_date"></td>
            <td class="px-4 py-3 text-right space-x-2">
              <button @@click="editOrder(order)" class="text-blue-600 hover:text-blue-800">✏️</button>
              <button @@click="deleteOrder(order.id)" class="text-red-600 hover:text-red-800">🗑️</button>
            </td>
          </tr>
        </template>
      </tbody>
    </table>
  </div>

<!-- Пагинация -->
  <div class="flex justify-between items-center mt-6 text-sm text-gray-600">
    <p x-text="`Показано ${paginatedPosts.length} из ${posts.length} статей`"></p>
    <div class="flex items-center space-x-2">
      <button @@click="prevPage" class="px-3 py-1 border rounded-lg hover:bg-gray-200 transition">«</button>
      <template x-for="page in totalPages" :key="page">
        <button @@click="currentPage = page"
                :class="{'bg-teal-600 text-white': currentPage === page, 'border px-3 py-1 rounded-lg hover:bg-gray-200 transition': true}"
                x-text="page"></button>
      </template>
      <button @@click="nextPage" class="px-3 py-1 border rounded-lg hover:bg-gray-200 transition">»</button>
    </div>
  </div>

  <!-- Модальное окно -->
  <div x-show="showModal" x-transition
       class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50"
       @@click.self="closeModal">
    <div class="bg-white text-gray-800 rounded-xl shadow-lg w-full max-w-3xl p-6 overflow-y-auto max-h-[90vh]">
      <h2 class="text-2xl font-semibold text-gray-800 mb-6"
          x-text="editId ? 'Редактировать заказ' : 'Добавить заказ'"></h2>

      <form class="space-y-4" submit.prevent="saveOrder">

        <div class="grid md:grid-cols-2 gap-4">

          <div>
            <label class="block text-sm text-gray-600 mb-1">Дата заказа</label>
            <input type="date" x-model="form.order_date"
                   class="w-full border border-gray-300 rounded-lg px-4 py-2">
          </div>

          <div>
            <label class="block text-sm text-gray-600 mb-1">SKU</label>
            <input type="text" x-model="form.sku"
                   class="w-full border border-gray-300 rounded-lg px-4 py-2">
          </div>

          <div>
            <label class="block text-sm text-gray-600 mb-1">Название</label>
            <input type="text" x-model="form.title"
                   class="w-full border border-gray-300 rounded-lg px-4 py-2">
          </div>

          <div>
            <label class="block text-sm text-gray-600 mb-1">Цвет</label>
            <input type="text" x-model="form.color"
                   class="w-full border border-gray-300 rounded-lg px-4 py-2">
          </div>

          <div>
            <label class="block text-sm text-gray-600 mb-1">Количество</label>
            <input type="number" x-model="form.quantity"
                   class="w-full border border-gray-300 rounded-lg px-4 py-2">
          </div>

          <div>
            <label class="block text-sm text-gray-600 mb-1">Цена (₽)</label>
            <input type="number" x-model="form.price"
                   class="w-full border border-gray-300 rounded-lg px-4 py-2">
          </div>

          <div>
            <label class="block text-sm text-gray-600 mb-1">Тип доставки</label>
            <select x-model="form.delivery_type"
                    class="w-full border border-gray-300 rounded-lg px-4 py-2">
              <option>На адрес</option>
              <option>Техцентр сборки</option>
              <option>Пакомат</option>
            </select>
          </div>

          <div>
            <label class="block text-sm text-gray-600 mb-1">Адрес доставки</label>
            <input type="text" x-model="form.delivery_address"
                   class="w-full border border-gray-300 rounded-lg px-4 py-2">
          </div>

          <div class="flex items-center">
            <input type="checkbox" x-model="form.assembly" class="mr-2">
            <span>Сборка требуется</span>
          </div>

          <div class="flex items-center">
            <input type="checkbox" x-model="form.paid" class="mr-2">
            <span>Оплачено</span>
          </div>

          <div>
            <label class="block text-sm text-gray-600 mb-1">Дата доставки</label>
            <input type="date" x-model="form.delivery_date"
                   class="w-full border border-gray-300 rounded-lg px-4 py-2">
          </div>

          <div>
            <label class="block text-sm text-gray-600 mb-1">Статус заказа</label>
            <select x-model="form.status"
                    class="w-full border border-gray-300 rounded-lg px-4 py-2">
              <option>Заказано</option>
              <option>В пути</option>
              <option>Доставлено</option>
            </select>
          </div>
        </div>

        <!-- Кнопки -->
        <div class="flex justify-end gap-4 pt-4 border-t border-gray-200 mt-6">
          <button type="button" @@click="closeModal"
                  class="px-5 py-2 bg-gray-300 text-gray-800 rounded-lg hover:bg-gray-400 transition">
            Отмена
          </button>
          <button type="submit"
                  class="px-5 py-2 bg-teal-600 text-white rounded-lg hover:bg-teal-500 transition">
            💾 Сохранить
          </button>
        </div>

      </form>
    </div>
  </div>
</main>

<script>
function ordersAdmin() {
  return {
    posts: [
      { id: 1, order_date: '2025-11-01', sku: 'A123', title: 'Электросамокат Rovery X1', color: 'Черный', quantity: 1, price: 49900, delivery_type: 'На адрес', delivery_address: 'г. Москва, ул. Пушкина, 10', assembly: true, paid: true, status: 'Заказано', delivery_date: '' },
      { id: 2, order_date: '2025-10-28', sku: 'B222', title: 'Велосипед Rovery Sport', color: 'Синий', quantity: 2, price: 39800, delivery_type: 'Пакомат', delivery_address: 'г. Санкт-Петербург, Пакомат #23', assembly: false, paid: false, status: 'Доставлено', delivery_date: '2025-11-03' },
      { id: 3, order_date: '2025-11-02', sku: 'C333', title: 'Электровелосипед Rovery X2', color: 'Белый', quantity: 1, price: 89900, delivery_type: 'На адрес', delivery_address: 'г. Казань, ул. Ленина, 25', assembly: true, paid: false, status: 'В обработке', delivery_date: '' },
      { id: 4, order_date: '2025-10-27', sku: 'D444', title: 'Самокат Rovery Mini', color: 'Красный', quantity: 3, price: 25900, delivery_type: 'Пакомат', delivery_address: 'г. Нижний Новгород, Пакомат #12', assembly: false, paid: true, status: 'Доставлено', delivery_date: '2025-11-04' },
      { id: 5, order_date: '2025-10-25', sku: 'E555', title: 'Велосипед Rovery City', color: 'Зеленый', quantity: 1, price: 32900, delivery_type: 'На адрес', delivery_address: 'г. Самара, ул. Гагарина, 50', assembly: true, paid: true, status: 'Заказано', delivery_date: '' },
      { id: 6, order_date: '2025-10-20', sku: 'F666', title: 'Электровелосипед Rovery Power', color: 'Черный', quantity: 2, price: 109900, delivery_type: 'На адрес', delivery_address: 'г. Москва, ул. Арбат, 33', assembly: true, paid: true, status: 'Доставлено', delivery_date: '2025-11-05' },
    ],
    form: { order_date: '', sku: '', title: '', color: '', quantity: 1, price: '', delivery_type: '', delivery_address: '', assembly: false, paid: false, status: 'Заказано', delivery_date: '' },
    showModal: false,
    editId: null,
    searchQuery: '',
    sortField: 'id',
    sortAsc: true,

    // 🔹 Пагинация
    currentPage: 1,
    perPage: 3,
    get totalPages() {
      return Math.ceil(this.filteredOrders.length / this.perPage);
    },
    get paginatedPosts() {
      const start = (this.currentPage - 1) * this.perPage;
      return this.filteredOrders.slice(start, start + this.perPage);
    },
    nextPage() {
      if (this.currentPage < this.totalPages) this.currentPage++;
    },
    prevPage() {
      if (this.currentPage > 1) this.currentPage--;
    },

    // 🔹 Фильтрация и сортировка
    get filteredOrders() {
      const search = this.searchQuery.toLowerCase();
      return this.sortedOrders.filter(o =>
        o.title.toLowerCase().includes(search) || String(o.id).includes(search)
      );
    },
    get sortedOrders() {
      return [...this.posts].sort((a, b) => {
        const fa = a[this.sortField];
        const fb = b[this.sortField];
        if (fa < fb) return this.sortAsc ? -1 : 1;
        if (fa > fb) return this.sortAsc ? 1 : -1;
        return 0;
      });
    },
    sort(field) {
      if (this.sortField === field) this.sortAsc = !this.sortAsc;
      else this.sortField = field;
    },

    // 🔹 CRUD
    openModal() { this.showModal = true; this.editId = null; },
    closeModal() { this.showModal = false; },
    saveOrder() {
      if (this.editId) {
        const index = this.posts.findIndex(o => o.id === this.editId);
        this.posts[index] = { ...this.form, id: this.editId };
      } else {
        const newId = this.posts.length ? Math.max(...this.posts.map(o => o.id)) + 1 : 1;
        this.posts.push({ ...this.form, id: newId });
      }
      this.closeModal();
    },
    editOrder(order) {
      this.editId = order.id;
      this.form = JSON.parse(JSON.stringify(order));
      this.showModal = true;
    },
    deleteOrder(id) {
      this.posts = this.posts.filter(o => o.id !== id);
    }
  };
}
</script>

</body>
</html>
