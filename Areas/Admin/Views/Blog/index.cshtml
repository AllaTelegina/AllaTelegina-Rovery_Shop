@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Блог";
}

<div x-data="{ filter: '', open: false, selected: null }">

<div class="flex justify-between items-center mb-4">
    <h2 class="text-2xl font-bold">Посты блога</h2>
    <button @click="open = true" class="bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700">Добавить пост</button>
</div>

<input type="text" placeholder="Поиск по заголовку..." x-model="filter" class="p-2 border rounded mb-4 w-full" />

<table class="w-full bg-white rounded shadow overflow-hidden">
    <thead class="bg-gray-100">
        <tr>
            <th class="p-2">ID</th>
            <th class="p-2">Название</th>
            <th class="p-2">Дата</th>
            <th class="p-2">Действия</th>
        </tr>
    </thead>
    <tbody>
        <tr class="border-b" x-show="true">
            <td class="p-2">1</td>
            <td class="p-2">Новый велосипедный обзор</td>
            <td class="p-2">01.09.2025</td>
            <td class="p-2">
                <button @click="selected = { title: 'Новый велосипедный обзор', content: 'Текст поста...' }" class="text-blue-600 hover:underline">Просмотр</button>
            </td>
        </tr>
    </tbody>
</table>

<!-- Модальное окно просмотра поста -->
<div x-show="selected" class="fixed inset-0 flex items-center justify-center bg-black bg-opacity-50 z-50">
    <div class="bg-white rounded shadow-lg p-6 w-1/2" @click.away="selected = null">
        <h3 class="text-xl font-semibold mb-4" x-text="selected.title"></h3>
        <p x-text="selected.content"></p>
        <div class="flex justify-end mt-4">
            <button @click="selected = null" class="px-4 py-2 rounded border">Закрыть</button>
        </div>
    </div>
</div>

</div>
