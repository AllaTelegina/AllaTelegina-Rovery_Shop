@* Areas/Admin/Views/Shared/_AdminLayout.cshtml *@
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Админка</title>
    <link rel="stylesheet" href="~/css/output.css" />
    <script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
</head>
<body class="bg-gray-100 text-gray-800">

<div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="w-64 bg-gray-900 text-white flex flex-col">
        <div class="p-4 text-2xl font-bold border-b border-gray-700">AdminPanel</div>
        <nav class="flex-1 mt-4">
            <ul>
                <li><a href="/Admin/Dashboard" class="block p-3 hover:bg-gray-700">📊 Dashboard</a></li>
                <li><a href="/Admin/Products" class="block p-3 hover:bg-gray-700">🛍️ Товары</a></li>
                <li><a href="/Admin/Orders" class="block p-3 hover:bg-gray-700">📦 Заказы</a></li>
                <li><a href="/Admin/Blog" class="block p-3 hover:bg-gray-700">📝 Блог</a></li>
                <li><a href="/Admin/Comments" class="block p-3 hover:bg-gray-700">💬 Комментарии</a></li>
                <li><a href="/Admin/Reviews" class="block p-3 hover:bg-gray-700">⭐ Отзывы</a></li>
                <li><a href="/Admin/Feedback" class="block p-3 hover:bg-gray-700">✉️ Feedback</a></li>
                <li><a href="/Admin/Users" class="block p-3 hover:bg-gray-700">👥 Пользователи</a></li>
                <li><a href="/Admin/Reports" class="block p-3 hover:bg-gray-700">📈 Отчёты</a></li>
            </ul>
        </nav>
        <div class="p-4 border-t border-gray-700">
            <a href="/Account/Logout" class="block text-sm text-gray-300 hover:text-white">🚪 Выйти</a>
        </div>
    </aside>

    <!-- Main content -->
    <main class="flex-1 flex flex-col">
        <header class="bg-white shadow p-4 flex justify-between items-center">
            <h1 class="text-xl font-semibold">@ViewData["Title"]</h1>
        </header>
        <section class="flex-1 p-6">
            @RenderBody()
        </section>
    </main>
</div>

</body>
</html>
