<html lang="pl">
<head>
      <meta charset="UTF-8">
      <title>AdminPanel</title>
      <link href="/css/output.css" rel="stylesheet">
      <script src="https://cdn.tailwindcss.com"></script>
      <!-- Alpine.js (defer - скрипт ждёт загрузки DOM) -->
      <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
      <!-- Flowbite JS (версия 2.3.0) -->
      <script defer src="https://unpkg.com/flowbite@2.3.0/dist/flowbite.min.js"></script>
      <!-- основной JS -->
<script defer src="/jsfile/Validate_Product_adminPanel.js"></script>
<script defer src="/js/main.js"></script>
</head>
<body class="flex flex-col min-h-screen">

<div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="w-64 bg-gray-900 text-white flex flex-col">
        <div class="p-4 text-2xl font-bold border-b border-teal-600">AdminPanel</div>
        <nav class="flex-1 mt-4">
            <ul>
                <li><a asp-action="Index" asp-controller="Dashboard" class="block p-3 hover:bg-teal-600">📊 Dashboard</a></li>
                <li><a href="@Url.Action("ProductsView", "Product")" class="block p-3 hover:bg-teal-600">🛍️ Товары</a></li>
                <li><a href="@Url.Action("OrdersMetod", "Orders")" class="block p-3 hover:bg-teal-600">📦 Заказы</a></li>
                <li><a href="@Url.Action("BlogMetod", "Blog")" class="block p-3 hover:bg-teal-600">📝 Блог</a></li>
                <li><a href="@Url.Action("CommentsMetod", "Comments")" class="block p-3 hover:bg-teal-600">💬 Комментарии</a></li>
                <li><a href="@Url.Action("ReviewMetod", "Review")" class="block p-3 hover:bg-teal-600">⭐ Отзывы</a></li>
                <li><a href="@Url.Action("FeedBackMethod", "FeedBack")" class="block p-3 hover:bg-teal-600">✉️ Feedback</a></li>
                <li><a href="@Url.Action("UsersMethod", "Users")" class="block p-3 hover:bg-teal-600">👥 Пользователи</a></li>
                <li><a href="@Url.Action("ReportsMethod", "Reports")" class="block p-3 hover:bg-teal-600">📈 Отчёты</a></li>
            </ul>
        </nav>
        <div class="p-4 border-t border-teal-600">
            <a href="/Account/Logout" class="block text-sm text-gray-300 hover:text-red-600">🚪 Выйти</a>
        </div>
    </aside>

    <!-- Main content -->
    <main class="flex-1 flex flex-col">
        <header class="bg-white shadow p-4 flex justify-between items-center">
            <h1 class="text-xl font-semibold">@ViewData["Title"]</h1>
        </header>
        <!--<aside class="w-64 bg-gray-900 text-white flex flex-col border-r border-teal-600"></aside>-->
            @RenderBody()
        </section>
    </main>
</div>

</body>
</html>
