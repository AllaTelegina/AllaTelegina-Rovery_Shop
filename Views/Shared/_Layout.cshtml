<!DOCTYPE html>
<html lang="pl" class="h-full">
<head>

    <meta charset="UTF-8">
    <title>index</title>
    <link href="output.css" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Alpine.js (defer - скрипт ждёт загрузки DOM) -->
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>

    <!-- Flowbite JS (версия 2.3.0) -->
    <script defer src="https://unpkg.com/flowbite@2.3.0/dist/flowbite.min.js"></script>

    <!-- Подключение .js файла для волидации формы;-->
    <script src="/jsfile/validate_fields_now.js"></script>

    <!-- основной JS -->
    <script type="module" defer src="./main.js"></script>
</head>

<body class="flex flex-col min-h-screen">


    <header class="fixed top-0 left-0 w-full z-50" x-data="{ mobileMenuOpen: false }">
        <!-- Затемнение фона при открытом меню -->
        <div x-show="mobileMenuOpen"
             x-transition.opacity
             class="fixed inset-0 z-40 bg-black/40 backdrop-blur-sm md:hidden"
        @@click="mobileMenuOpen = false"></div>

        <nav class="bg-teal-400 border-gray-100 shadow-lg dark:border-gray-600 dark:bg-gray-900 z-50 relative">
            <div class="flex flex-wrap justify-between items-center mx-auto max-w-screen-2xl px-4 md:px-8 py-4">

                <!-- Логотип -->
                <a asp-controller="Home" asp-action="Index" class="flex items-center space-x-3 rtl:space-x-reverse">
                    <img src="../assets/images/rover.png" class="h-8" alt="Logo" />
                    <span class="uppercase self-center text-xl font-semibold whitespace-nowrap text-white hover:bg-teal-800 md:hover:bg-transparent md:border-0 md:hover:text-teal-800" aria-label="Logo" title="На главную">Telegin</span>
                </a>

                <!-- Кнопка меню -->
