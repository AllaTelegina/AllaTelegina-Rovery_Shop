@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
ViewBag.Error;
@model UserRovery;
<section class="bg-white dark:bg-gray-900 flex items-center justify-center min-h-screen px-4">

    <div class="w-full max-w-md p-6 bg-white rounded-lg shadow dark:bg-gray-800">

        <p class="text-sm text-gray-600 dark:text-gray-300 mb-6 text-center">
            Wprowadź nowe hasło.
        </p>

        <form action="#" method="POST" class="space-y-5">
            @Html.AntiForgeryToken()
            <div>
                <label for="Haslo" class="block text-sm font-medium text-gray-900 dark:text-white">Haslo</label>
                <input type="Id" asp-for="Id" hidden/>
                <input type="password" id="password" asp-for="Password"
                       class="mt-1 block w-full p-2.5 border border-gray-200 rounded-lg text-sm bg-gray-50 text-gray-900 focus:ring-teal-700 focus:border-teal-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white">
            </div>
            <button type="submit" asp-controller="RegisterUser" asp-action="ChengePassword"
                    class="w-full py-2.5 px-4 text-sm font-medium uppercase text-white bg-teal-600 hover:bg-red-600 focus:ring-4 focus:outline-none focus:ring-teal-500 rounded-lg dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800">
                Zmień hasło
            </button>
        </form>

        <div class="mt-6 text-center">
            <a href="/dist/index.cshtml"
               class="text-sm text-teal-800 hover:text-red-800 hover:underline dark:text-blue-400">Wróć do wejścia</a>
        </div>
    </div>

</section>

