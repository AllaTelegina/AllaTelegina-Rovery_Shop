@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<title>forgot_password</title>
ViewBag.Error;
@model UserRovery;
<section class="bg-white dark:bg-gray-900 flex items-center justify-center min-h-screen px-4">

    <div class="w-full max-w-md p-6 bg-white rounded-lg shadow dark:bg-gray-800">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4 text-center">Odzyskiwanie hasła</h2>
    
        <p class="text-sm text-gray-600 dark:text-gray-300 mb-6 text-center">
            Wprowadź adres e-mail powiązany z Twoim kontem, a my wyślemy Ci link umożliwiający zresetowanie hasła.
        </p>

        <form action="#" method="POST" class="space-y-5">
            <div>
                <label for="email" class="block text-sm font-medium text-gray-900 dark:text-white">Email</label>
                <input placeholder="maxpesfix@inbox." type="email" id="email" asp-for="Email" 
                        class="mt-1 block w-full p-2.5 border border-gray-200 rounded-lg text-sm bg-gray-50 text-gray-900 focus:ring-teal-700 focus:border-teal-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white">
            </div>
            @* Вставка  ошибки валидации начало *@
            @if (ViewBag.Error != null)
            {
                <div role="alert" class="flex items-center p-4 mb-4 text-sm text-red-700 bg-red-100 rounded-lg dark:bg-red-800 dark:text-red-200">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span>@ViewBag.Error</span>
                </div>
            }
            @* Ошибка валидации конец *@
            <button type="submit" asp-controller="RegisterUser" asp-action="If_FogotPassword"
                    class="w-full py-2.5 px-4 text-sm font-medium uppercase text-white bg-teal-600 hover:bg-red-600 focus:ring-4 focus:outline-none focus:ring-teal-500 rounded-lg dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800">
                    Wyślij link resetujący
            </button>
        </form>

    <div class="mt-6 text-center">
        <a asp-controller="RegisterUser" asp-action="Index" 
            class="text-sm text-teal-800 hover:text-red-800 hover:underline dark:text-blue-400">Wróć do wejścia</a>
    </div>
    </div>

</section>

