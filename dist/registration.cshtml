@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@model DotnetModel;
<html lang="pl" class="h-full">
    <head>
        <meta charset="UTF-8">
        <title>Rejestracja</title>
        <link href="output.css" rel="stylesheet">
        <script src="https://cdn.tailwindcss.com"></script>

        <!-- Alpine.js (defer - скрипт ждёт загрузки DOM) -->
        <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>

        <!-- Flowbite JS (версия 2.3.0) -->
        <script defer src="https://unpkg.com/flowbite@2.3.0/dist/flowbite.min.js"></script>

        <!-- основной JS -->
        <script type="module" defer src="./main.js"></script>
    </head>

    <!-- registration.cshtml -->


    <body class="flex flex-col min-h-screen">


        <!-- Модальное окно вход header+ -->
        <div id="authentication-modal" tabindex="-1" aria-hidden="true" 
            class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 
            inset-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full">
            <div class="relative p-4 w-full max-w-md max-h-full">
                <!-- Modal content -->
                <div class="relative bg-white rounded-lg shadow-sm dark:bg-gray-700">
                    <!-- Modal header -->
                    <div class="flex items-center justify-between p-4 md:p-5 border-b rounded-t dark:border-gray-600 border-gray-200">
                        <h3 class="text-xl font-semibold text-gray-900 dark:text-white">
                            Zaloguj się na swoje konto osobiste
                        </h3>
                        <button type="button" class="end-2.5 text-gray-400 bg-transparent hover:bg-gray-200 hover:text-gray-900 rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center dark:hover:bg-gray-600 dark:hover:text-white" data-modal-hide="authentication-modal">
                            <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
                            </svg>
                            <span class="sr-only">Close modal</span>
                        </button>
                    </div>
                    <!-- Modal body -->
                    <div class="p-4 md:p-5">
                        <div 
                            @@click="mode = 'login'" 
                            x-show="mode === 'login' || window.innerWidth >= 640" 
                            x-cloak 
                            :class="mode === 'login' ? 'ring-2 ring-teal-200' : ''"
                            class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow transition-all">
       
                            <form class="space-y-4" action="#" method="post">
                                <div>
                                    <label for="email" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Twój e-mail</label>
                                    <input type="email" asp-for="UserRovery.Email" id="email" class="border border-teal-300 text-gray-900 text-sm rounded-lg focus:ring-teal-700 focus:border-teal-500 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white" placeholder="name@company.com" required />
                                </div>
                                <div>
                                    <label for="password" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Twoje hasło</label>
                                    <input type="password" asp-for="UserRovery.Password" id="password" placeholder="••••••••" class="border border-teal-300 text-gray-900 text-sm rounded-lg focus:ring-teal-700 focus:border-teal-500 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white" required />
                                </div>
                                <div class="flex justify-between">
                                    <div class="flex items-start">
                            
                                        <div x-data="{ checked: false }" class="flex items-center text-sm cursor-pointer space-x-2">
                                            <!-- Кастомный чекбокс -->
                                            <div @@click="checked = !checked" class="w-5 h-5 border border-gray-400 rounded flex items-center justify-center"
                                                    :class="{ 'bg-teal-500 border-teal-500': checked }">
                                                <!-- Галочка -->
                                                <svg x-show="checked" xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24"
                                                    stroke="currentColor" stroke-width="4">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                                                </svg>
                                            </div>

                                            <!-- Текст и скрытый checkbox для форм -->
                                            <label for="remember" class="ms-2 text-sm  text-gray-900 dark:text-gray-300">
                                                <input type="checkbox" id="terms" name="terms" x-model="checked" class="hidden" required />
                                                Pamiętaj mnie
                                            </label>
                                        </div>
                          
                                    </div>
                                    <a href="/dist/forgot_password.html" class="text-sm font-medium hover:text-teal-500 text-red-700 hover:underline dark:text-blue-500">Zapomniałem hasła?</a>
                                </div>

                                <div class="mt-6">
                                    <div class="relative">
                                        <div class="absolute inset-0 flex items-center">
                                            <div class="w-full border-t border-teal-500"></div>
                                        </div>
                                        <div class="relative flex justify-center text-sm">
                                            <span class="bg-white dark:bg-teal-700 px-2 text-gray-500 dark:text-white">Login using</span>
                                        </div>
                                    </div>
                                    <button
                                        class="inline-flex w-full items-center justify-center rounded-md border border-teal-700 bg-white dark:bg-gray-700 px-4 py-2 text-sm font-medium text-teal-700 hover:text-white dark:text-white shadow-sm hover:bg-teal-400 dark:hover:bg-gray-600 disabled:cursor-wait disabled:opacity-50">
                                        <span class="sr-only">Sign in with Google</span>
                                        <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                            <clipPath id="p.0">
                                                <path d="m0 0l20.0 0l0 20.0l-20.0 0l0 -20.0z" clip-rule="nonzero"></path>
                                            </clipPath>
                                            <g clip-path="url(#p.0)">
                                                <path fill="currentColor" fill-opacity="0.0" d="m0 0l20.0 0l0 20.0l-20.0 0z"
                                                    fill-rule="evenodd"></path>
                                                <path fill="currentColor"
                                                    d="m19.850197 8.270351c0.8574047 4.880001 -1.987587 9.65214 -6.6881847 11.218641c-4.700598 1.5665016 -9.83958 -0.5449295 -12.08104 -4.963685c-2.2414603 -4.4187555 -0.909603 -9.81259 3.1310139 -12.6801605c4.040616 -2.867571 9.571754 -2.3443127 13.002944 1.2301085l-2.8127813 2.7000687l0 0c-2.0935059 -2.1808972 -5.468274 -2.500158 -7.933616 -0.75053835c-2.4653416 1.74962 -3.277961 5.040613 -1.9103565 7.7366734c1.3676047 2.6960592 4.5031037 3.9843292 7.3711267 3.0285425c2.868022 -0.95578575 4.6038647 -3.8674583 4.0807285 -6.844941z"
                                                    fill-rule="evenodd"></path>
                                                <path fill="currentColor" d="m10.000263 8.268785l9.847767 0l0 3.496233l-9.847767 0z"
                                                    fill-rule="evenodd"></path>
                                            </g>
                                        </svg>
                                    </button>
                                </div>
                            <button type="submit" class="w-full uppercase text-white hover:bg-red-600 bg-teal-600 focus:ring-4 focus:outline-none focus:ring-teal-500 font-medium rounded-lg text-sm px-5 py-3.5 text-center dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800">wejście</button>
                                <div class="text-sm font-medium text-gray-500 dark:text-gray-300">
                                    Nie jesteś zarejestrowany?
                                    <a href="/dist/registration.html" class="hover:text-teal-800 text-red-700 hover:underline dark:text-blue-500">Utwórz konto</a> 
                                </div>
                            </form>
        
                        </div>
                    </div>
                </div>
            </div>
        </div> 


        <!-- Модальное окно поиска header+ -->
        <div id="search-modal" tabindex="-1" aria-hidden="true"
          class="hidden fixed inset-0 z-50 w-full p-4 overflow-x-hidden overflow-y-auto flex items-start justify-center pt-20 sm:pt-32">

          <!-- Контейнер формы -->
          <div class="relative w-full max-w-xl sm:max-w-2xl lg:max-w-7xl">
            <div class="relative bg-gray-800/10 rounded-xl shadow dark:bg-gray-700 p-6 lg:p-10 min-h-[280px] lg:min-h-[360px]">
              <!-- Кнопка закрытия -->
              <button type="button"
                class="absolute top-2 right-2 text-white bg-transparent hover:bg-gray-200 hover:text-teal-600 rounded-lg text-sm w-8 h-8 flex items-center justify-center dark:hover:bg-gray-600 dark:hover:text-white"
                data-modal-hide="search-modal">
                <svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                  <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M1 1l6 6m0 0l6 6M7 7l6-6M7 7L1 13" />
                </svg>
                <span class="sr-only">Закрыть</span>
              </button>

              <!-- Форма поиска -->
              <form class="mt-6">
                <div class="relative w-full">
                  <input placeholder="e.g. Blog"
                    class="rounded-full w-full h-16 bg-white py-2 pl-8 pr-32 outline-none border-2 border-gray-200 shadow-md hover:outline-none focus:ring-teal-200 focus:border-teal-200 dark:bg-gray-600 dark:border-gray-500 dark:text-white"
                    type="text" name="query" id="query">

                  <button type="submit"
                    class="absolute inline-flex items-center h-10 px-4 py-2 text-sm text-white transition duration-150 ease-in-out rounded-full right-3 top-3 bg-teal-600 sm:px-6 sm:text-base sm:font-medium hover:bg-teal-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-teal-500">
                    <svg class="-ml-0.5 sm:-ml-1 mr-2 w-4 h-4 sm:h-5 sm:w-5" xmlns="http://www.w3.org/2000/svg" fill="none"
                      viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                    Search
                  </button>
                </div>
              </form>
            </div>
          </div>
        </div>


        <main class="flex-grow container mx-auto mt-20">

            <div class="mb-6 flex flex-col gap-4 sm:mb-8 md:mb-12">
                <div class="bg-white dark:bg-gray-800 sm:py-8 lg:py-4 container px-2 py-1 ">
                    <div class="max-w-screen-3xl px-2 py-4 md:px-8 mx-auto">


                        <div class="mb-6 flex flex-col sm:flex-row items-start sm:items-center justify-between sm:gap-2 sm:mb-8 md:mb-12">
                          <h1 class="text-2xl font-bold text-teal-800 lg:text-3xl dark:text-white">Dlaczego warto się zarejestrować? - Wszystko dla Twojej wygody</h1>
                          <!-- Хлебные крошки -->
                            <nav class="flex" aria-label="Breadcrumb">
                                <ol class="inline-flex items-center space-x-1 md:space-x-2 rtl:space-x-reverse">
                                    <li class="inline-flex items-center">
                                        <a href="#" class="inline-flex items-center text-sm font-medium text-teal-700 hover:text-red-700 dark:text-gray-400 dark:hover:text-white">
                                            <svg class="w-3 h-3 me-2.5" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20">
                                                <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
                                            </svg>
                                            Dom
                                        </a>
                                    </li>
                                    <li aria-current="page">
                                        <div class="flex items-center">
                                            <svg class="rtl:rotate-180 w-3 h-3 text-gray-400 mx-1" fill="none" viewBox="0 0 6 10">
                                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
                                            </svg>
                                            <span class="ms-1 text-sm font-medium text-gray-500 md:ms-2 dark:text-gray-400">Rejestracja</span>
                                        </div>
                                    </li>
                                </ol>
                            </nav>
                        </div>

                        <div class="max-w-7xl mx-auto">

                            <section>
                                <div class="bg-white dark:bg-gray-800 sm:py-8 lg:py-2 container px-2 mx-auto">
                                    <div class="mx-auto max-w-screen-2xl px-2 py-6 md:px-8">
                                        <div id="features" class="mx-auto max-w-8xl">
                                            <ul class="mt-4 grid grid-cols-1 gap-6 text-center text-slate-700 md:grid-cols-3">
      

                                                <li class="flex flex-col items-center text-center rounded-lg bg-white border border-teal-200 hover:border-teal-400 shadow-2xl aspect-auto shadow-gray-600/10 px-6 py-8 transition-transform duration-300 hover:scale-105 hover:shadow-lg">
                                                    <a href="#" class="group flex flex-col items-center text-center">
                                                        <svg class="w-[39px] h-[39px] text-teal-700 dark:text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.891 15.107 15.11 8.89m-5.183-.52h.01m3.089 7.254h.01M14.08 3.902a2.849 2.849 0 0 0 2.176.902 2.845 2.845 0 0 1 2.94 2.94 2.849 2.849 0 0 0 .901 2.176 2.847 2.847 0 0 1 0 4.16 2.848 2.848 0 0 0-.901 2.175 2.843 2.843 0 0 1-2.94 2.94 2.848 2.848 0 0 0-2.176.902 2.847 2.847 0 0 1-4.16 0 2.85 2.85 0 0 0-2.176-.902 2.845 2.845 0 0 1-2.94-2.94 2.848 2.848 0 0 0-.901-2.176 2.848 2.848 0 0 1 0-4.16 2.849 2.849 0 0 0 .901-2.176 2.845 2.845 0 0 1 2.941-2.94 2.849 2.849 0 0 0 2.176-.901 2.847 2.847 0 0 1 4.159 0Z"/>
                                                        </svg>
                                                        <h3 class="my-3 text-lg font-medium uppercase">Spersonalizowane oferty i rabaty</h3>
                                                        <p class="mt-1.5 text-base leading-6 text-secondary-500">   
                                                             Otrzymuj specjalne promocje, spersonalizowane rekomendacje i świetne 
                                                             oferty tylko dla zarejestrowanych użytkowników.
                                                        </p>
                                                    </a>
                                                </li>

                                                <li class="flex flex-col items-center text-center rounded-lg bg-white border border-teal-200 hover:border-teal-400 shadow-2xl aspect-auto shadow-gray-600/10 px-6 py-8 transition-transform duration-300 hover:scale-105 hover:shadow-lg">
                                                    <svg class="w-[34px] h-[34px] text-teal-700 dark:text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M6 14h2m3 0h5M3 7v10a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1V7a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1Z"/>
                                                    </svg>
                                                    <h3 class="my-3 text-lg font-medium uppercase group-hover:text-primary-500">
                                                               Szybka płatność i zapisane adresy
                                                    </h3>
                                                    <p class="mt-1.5 text-base leading-6 text-secondary-500">
                                                          Nie marnuj czasu na ponowne wprowadzanie danych - zapisz adresy 
                                                          dostawy i zapłać za zakupy kilkoma kliknięciami.
                                                    </p>
                                                </li>
                                                <li class="flex flex-col items-center text-center rounded-lg bg-white border border-teal-200 hover:border-teal-400 shadow-2xl aspect-auto shadow-gray-600/10 px-6 py-8 transition-transform duration-300 hover:scale-105 hover:shadow-lg">
                                                    <svg class="w-[34px] h-[34px] text-teal-700 dark:text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 8h6m-6 4h6m-6 4h6M6 3v18l2-2 2 2 2-2 2 2 2-2 2 2V3l-2 2-2-2-2 2-2-2-2 2-2-2Z"/>
                                                    </svg>
                                                    <h3 class="my-3 text-lg font-medium uppercase group-hover:text-primary-500">Wygodna kontrola zamówień</h3>
                                                    <p class="mt-1.5 text-base leading-6 text-secondary-500">
                                                         Monitoruj status swoich zamówień online i przeglądaj historię 
                                                         zakupów na swoim koncie osobistym.
                                                    </p>
        
                                                </li>
                                            </ul>
                                        </div>

                                    </div>
                                </div>
                            </section>
  
                            <!-- Регистрация -->
                            <div 
                                @@click="mode = 'register'" 
                                x-show="mode === 'register' || window.innerWidth >= 640" 
                                x-cloak 
                                :class="mode === 'register' ? 'ring-2 ring-teal-200' : ''"
                                class="bg-white dark:bg-gray-800 p-6 sm:p-4 rounded-lg shadow transition-all 
                                w-full max-w-md md:max-w-md lg:max-w-lg mx-auto flex flex-col justify-center">
                                <h2 class="text-xl font-bold mb-4 text-center">Twoje konto</h2>
                                <form class="space-y-4" asp-controller="RegisterUser" asp-action="Register_User" method="post">
                                    @Html.AntiForgeryToken()
                                    <div class="mb-5">
                                        <label for="name" class="mb-3 block text-base font-medium text-[#07074D]">
                                            Name
                                        </label>
                                    <input type="text" asp-for="UserRovery.Name" id="name" placeholder="Name"
                                           class="border border-teal-300 text-gray-900 text-sm rounded-lg focus:ring-teal-700 focus:border-teal-500 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white" />
                                    </div>
                                    <div class="mb-5">
                                        <label for="name" class="mb-3 block text-base font-medium text-[#07074D]"> Last Name </label>
                                        <input type="text" asp-for="UserRovery.LastName" id="Lastname" placeholder="Last Name"
                                            class="border border-teal-300 text-gray-900 text-sm rounded-lg focus:ring-teal-700 focus:border-teal-500 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white" />
                                    </div>
                                    <div>
                                        <label for="email" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Twój e-mail</label>
                                        <input type="email" asp-for="UserRovery.Email" id="email" class="border border-teal-300 text-gray-900 text-sm rounded-lg focus:ring-teal-700 focus:border-teal-500 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white" placeholder="name@company.com" required />

                                        @* Вставка  ошибки валидации начало *@
                                        @if (ViewBag.Error!=null)
                                        {
                                            <div role="alert" class="flex items-center p-4 mb-4 text-sm text-red-700 bg-red-100 rounded-lg dark:bg-red-800 dark:text-red-200">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                </svg>
                                                <span>@ViewBag.Error</span>
                                            </div>
                                        }
                                        @* Ошибка валидации конец *@

                                    </div>


                                    <div class="mb-5">
                                        <label for="phone" class="mb-3 block text-base font-medium text-[#07074D]"> Phone Number </label>
                                    <input type="text" asp-for="UserRovery.PhoneNumer" id="phone" placeholder="Enter your phone number"
                                            class="border border-teal-300 text-gray-900 text-sm rounded-lg focus:ring-teal-700 focus:border-teal-500 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white" />
                                    </div>
                                    <div class="mb-5">
                                        <label for="date" class="mb-3 block text-base font-medium text-[#07074D]"> Date of birth </label>
                                        <input type="date" asp-for="UserRovery.DateOfBirth" id="date"
                                            class="border border-teal-300 text-gray-900 text-sm rounded-lg focus:ring-teal-700 focus:border-teal-500 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white" />
                                    </div>

                                    <!-- Поле: Twoje hasło -->
                                    <div x-data="{ show: false }">
                                        <label for="password" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Twoje hasło</label>
                                        <div class="relative">
                                        <input asp-for="UserRovery.Password" :type="show ? 'text' : 'password'" id="password" placeholder="••••••••"
                                              class="border border-teal-300 text-gray-900 text-sm rounded-lg focus:ring-teal-700 focus:border-teal-500 block w-full p-2.5 pr-10 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white" required />
    
                                            <button type="button" @@click="show = !show" class="absolute inset-y-0 right-2 flex items-center text-gray-600 dark:text-gray-300">
                                                <svg x-show="!show" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                          d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                          d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7
                                                             -1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                                </svg>

                                                <svg x-show="show" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                          d="M13.875 18.825A10.05 10.05 0 0112 19c-4.477 0-8.268-2.943-9.542-7
                                                             a9.963 9.963 0 012.195-3.516M9.88 9.88a3 3 0 104.24 4.24M6.1 6.1L18 18" />
                                                </svg>
                                            </button>
                                        </div>
                                    </div>

                                    <!-- Повтор пароля -->
                                    <div class="mt-6" x-data="{ show: false }">
                                        <label for="password_confirmation" class="block text-sm font-medium text-gray-900 dark:text-white">Confirm Password</label>
                                        <div class="relative mt-1 rounded-md shadow-sm">
