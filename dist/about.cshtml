                                                            <a href="#" class="block mb-3 hover:underline">
                                                                  <h2 class="text-2xl font-bold leading-5 line-clamp-2 min-h-[2.5rem] text-black dark:text-white transition-colors duration-200 hover:text-red-700 dark:hover:text-purple-400">
                                                                        O firme
                                                                  </h2>
                                                            </a>
                                                            <div x-data="{ expanded: false }" class="mt-4">
