@using Newtonsoft.Json
<!-- строка подключения страницы _Layout, для того, чтоб открывался futer and header-->
@{
    Layout="~/Views/Shared/_Layout.cshtml";
}

<html lang="pl" class="dark h-full">
    <head>
        <script src="~/jsfile/SetProductInCatalog.js"></script>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>katalogy</title>
        <link href="output.css" rel="stylesheet" />
        <style>[x-cloak]{display:none !important;}</style>
        <script>
            tailwind.config = {
                darkMode: 'class'
            }
        </script>
        <script src="https://cdn.tailwindcss.com"></script>
        <!-- Alpine.js (defer - скрипт ждёт загрузки DOM) -->
        <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
        <!-- Flowbite JS (версия 2.3.0) -->
        <script defer src="https://unpkg.com/flowbite@2.3.0/dist/flowbite.min.js"></script>
        <!-- основной JS -->
        <script type="module" defer src="./main.js"></script>
        <script>
            document.addEventListener('alpine:init', () => {
                Alpine.store('ui', {
                    openFilters: false
                });
            });
        </script>
    </head>

    <body x-data="{ openFilters: false }" class="flex flex-col min-h-screen">

        <!-- Модальное окно вход -->
        <div id="authentication-modal" tabindex="-1" aria-hidden="true" class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 inset-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full">
            <div class="relative p-4 w-full max-w-md max-h-full">
                <!-- Modal content -->
                <div class="relative bg-white rounded-lg shadow-sm dark:bg-gray-700">
                    <!-- Modal header -->
                    <div class="flex items-center justify-between p-4 md:p-5 border-b rounded-t dark:border-gray-600 border-gray-200">
                        <h3 class="text-xl font-semibold text-gray-900 dark:text-white">
                            Zaloguj się na swoje konto osobiste
                        </h3>
                        <button type="button"
                                class="end-2.5 text-gray-400 bg-transparent hover:bg-gray-200 hover:text-gray-900 rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center dark:hover:bg-gray-600 dark:hover:text-white"
                                data-modal-hide="authentication-modal">
                            <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none"
                                viewBox="0 0 14 14">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
                                    stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6" />
                            </svg>
                            <span class="sr-only">Close modal</span>
                        </button>
                    </div>
                    <!-- Modal body -->
                    <div class="p-4 md:p-5">
                        <div @@click="mode = 'login'"
                            x-show="mode === 'login' || window.innerWidth >= 640"
                            x-cloak
                            :class="mode === 'login' ? 'ring-2 ring-teal-200' : ''"
                            class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow transition-all">

                            <form class="space-y-4" action="#">
                                <div>
                                    <label for="email"
                                        class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">
                                        Twój e-mail
                                    </label>
                                    <input type="email" name="email" id="email"
                                        class="border border-teal-300 text-gray-900 text-sm rounded-lg focus:ring-teal-700 focus:border-teal-500 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white"
                                        placeholder="name@company.com" required />
                                </div>
                                <div>
                                    <label for="password"
                                            class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">
                                        Twoje
                                        hasło
                                    </label>
                                    <input type="password" name="password" id="password" placeholder="••••••••"
                                            class="border border-teal-300 text-gray-900 text-sm rounded-lg focus:ring-teal-700 focus:border-teal-500 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white"
                                            required />
                                </div>
                                <div class="flex justify-between">
                                    <div class="flex items-start">

                                        <div x-data="{ checked: false }"
                                            class="flex items-center text-sm cursor-pointer space-x-2">
                                            <!-- Кастомный чекбокс -->
                                            <div @@click="checked = !checked"
                                                class="w-5 h-5 border border-gray-400 rounded flex items-center justify-center"
                                                :class="{ 'bg-teal-500 border-teal-500': checked }">
                                                <!-- Галочка -->
                                                <svg x-show="checked" xmlns="http://www.w3.org/2000/svg"
                                                    class="w-3 h-3 text-white" fill="none"
                                                    viewBox="0 0 24 24"
                                                    stroke="currentColor" stroke-width="4">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        d="M5 13l4 4L19 7" />
                                                </svg>
                                            </div>

                                            <!-- Текст и скрытый checkbox для форм -->
                                            <label for="remember"
                                                    class="ms-2 text-sm  text-gray-900 dark:text-gray-300">
                                                <input type="checkbox" id="terms" name="terms"
                                                        x-model="checked" class="hidden" required />
                                                Pamiętaj mnie
                                            </label>
                                        </div>

                                    </div>
                                    <a href="/dist/forgot_password.html"
                                        class="text-sm font-medium hover:text-teal-500 text-red-700 hover:underline dark:text-blue-500">
                                        Zapomniałem
                                        hasła?
                                    </a>
                                </div>

                                <div class="mt-6">
                                    <div class="relative">
                                        <div class="absolute inset-0 flex items-center">
                                            <div class="w-full border-t border-teal-500"></div>
                                        </div>
                                        <div class="relative flex justify-center text-sm">
                                            <span class="bg-white dark:bg-teal-700 px-2 text-gray-500 dark:text-white">Login using</span>
                                        </div>
                                    </div>
                                    <button class="inline-flex w-full items-center justify-center rounded-md border border-teal-700 bg-white dark:bg-gray-700 px-4 py-2 text-sm font-medium text-teal-700 hover:text-white dark:text-white shadow-sm hover:bg-teal-400 dark:hover:bg-gray-600 disabled:cursor-wait disabled:opacity-50">
                                        <span class="sr-only">Sign in with Google</span>
                                        <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"
                                            aria-hidden="true">
                                            <clipPath id="p.0">
                                                <path d="m0 0l20.0 0l0 20.0l-20.0 0l0 -20.0z"
                                                    clip-rule="nonzero"></path>
                                            </clipPath>
                                            <g clip-path="url(#p.0)">
                                                <path fill="currentColor" fill-opacity="0.0"
                                                    d="m0 0l20.0 0l0 20.0l-20.0 0z"
                                                    fill-rule="evenodd"></path>
                                                <path fill="currentColor"
                                                    d="m19.850197 8.270351c0.8574047 4.880001 -1.987587 9.65214 -6.6881847 11.218641c-4.700598 1.5665016 -9.83958 -0.5449295 -12.08104 -4.963685c-2.2414603 -4.4187555 -0.909603 -9.81259 3.1310139 -12.6801605c4.040616 -2.867571 9.571754 -2.3443127 13.002944 1.2301085l-2.8127813 2.7000687l0 0c-2.0935059 -2.1808972 -5.468274 -2.500158 -7.933616 -0.75053835c-2.4653416 1.74962 -3.277961 5.040613 -1.9103565 7.7366734c1.3676047 2.6960592 4.5031037 3.9843292 7.3711267 3.0285425c2.868022 -0.95578575 4.6038647 -3.8674583 4.0807285 -6.844941z"
                                                    fill-rule="evenodd"></path>
                                                <path fill="currentColor"
                                                    d="m10.000263 8.268785l9.847767 0l0 3.496233l-9.847767 0z"
                                                    fill-rule="evenodd"></path>
                                            </g>
                                        </svg>
                                    </button>
                                </div>
                                <button type="submit"
                                        class="w-full uppercase text-white hover:bg-red-600 bg-teal-600 focus:ring-4 focus:outline-none focus:ring-teal-500 font-medium rounded-lg text-sm px-5 py-3.5 text-center dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800">
                                    wejście
                                </button>
                                <div class="text-sm font-medium text-gray-500 dark:text-gray-300">
                                    Nie jesteś zarejestrowany?
                                    <a href="/dist/registration.html"
                                        class="hover:text-teal-800 text-red-700 hover:underline dark:text-blue-500">
                                        Utwórz konto
                                    </a>
                                </div>
                            </form>

                        </div>
                    </div>
                </div>
              </div>
          </div>


          <!-- Модальное окно поиска -->
          <div id="search-modal" tabindex="-1" aria-hidden="true"
               class="hidden fixed inset-0 z-50 w-full p-4 overflow-x-hidden overflow-y-auto flex items-start justify-center pt-20 sm:pt-32">

              <!-- Контейнер формы -->
              <div class="relative w-full max-w-xl sm:max-w-2xl lg:max-w-7xl">
                  <div class="relative bg-gray-800/10 rounded-xl shadow dark:bg-gray-700 p-6 lg:p-10 min-h-[280px] lg:min-h-[360px]">
                      <!-- Кнопка закрытия -->
                      <button type="button"
                              class="absolute top-2 right-2 text-white bg-transparent hover:bg-gray-200 hover:text-teal-600 rounded-lg text-sm w-8 h-8 flex items-center justify-center dark:hover:bg-gray-600 dark:hover:text-white"
                              data-modal-hide="search-modal">
                          <svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M1 1l6 6m0 0l6 6M7 7l6-6M7 7L1 13" />
                          </svg>
                          <span class="sr-only">Закрыть</span>
                      </button>

                      <!-- Форма поиска -->
                      <form class="mt-6">
                          <div class="relative w-full">
                              <input placeholder="e.g. Blog"
                                     class="rounded-full w-full h-16 bg-white py-2 pl-8 pr-32 outline-none border-2 border-gray-200 shadow-md hover:outline-none focus:ring-teal-200 focus:border-teal-200 dark:bg-gray-600 dark:border-gray-500 dark:text-white"
                                     type="text" name="query" id="query">

                              <button type="submit"
                                      class="absolute inline-flex items-center h-10 px-4 py-2 text-sm text-white transition duration-150 ease-in-out rounded-full right-3 top-3 bg-teal-600 sm:px-6 sm:text-base sm:font-medium hover:bg-teal-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-teal-500">
                                  <svg class="-ml-0.5 sm:-ml-1 mr-2 w-4 h-4 sm:h-5 sm:w-5"
                                       xmlns="http://www.w3.org/2000/svg" fill="none"
                                       viewBox="0 0 24 24" stroke="currentColor">
                                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                                  </svg>
                                  Search
                              </button>
                          </div>
                      </form>
                  </div>
              </div>
          </div>


          <!-- Мобильный фильтр (ОТДЕЛЬНЫЙ overlay, НЕ конфликтует с бургером) -->
          <div x-show="openFilters"
               x-transition.opacity
               @@click.self="openFilters = false"
               class="fixed inset-0 bg-black/50 z-[90] md:hidden">
              <div x-transition:enter="transition ease-out duration-200 transform"
                   x-transition:enter-start="-translate-x-full"
                   x-transition:enter-end="translate-x-0"
                   x-transition:leave="transition ease-in duration-150 transform"
                   x-transition:leave-start="translate-x-0"
                   x-transition:leave-end="-translate-x-full"
                   class="absolute left-0 top-0 w-72 h-full bg-white p-4 shadow-xl overflow-y-auto">
                  <button @@click="openFilters = false"
                          class="absolute top-2 right-2 text-gray-600 text-2xl">
                      &times;
                  </button>

                  <h2 class="text-xl font-semibold mb-4 text-gray-800">Фильтры</h2>

                  <!-- 1. Категория -->
                  <div class="mb-4">
                      <h3 class="font-medium text-gray-700 mb-1">Категория</h3>
                      <template x-for="item in categories" :key="item.value">
                          <label class="flex items-center gap-2 mb-1 cursor-pointer">
                              <input type="checkbox" x-model="selected.categories" :value="item.value" class="accent-teal-600">
                              <span x-text="item.label"></span>
                          </label>
                      </template>
                  </div>

                  <!-- 2. Тип -->
                  <div class="mb-4">
                      <h3 class="font-medium text-gray-700 mb-1">Тип</h3>
                      <template x-for="item in types" :key="item">
                          <label class="flex items-center gap-2 mb-1 cursor-pointer">
                              <input type="checkbox" x-model="selected.types" :value="item" class="accent-teal-600">
                              <span x-text="item"></span>
                          </label>
                      </template>
                  </div>

                  <!-- 3. Цена -->
                  <div class="mb-4">
                      <h3 class="font-medium text-gray-700 mb-1">Цена</h3>
                      <div class="flex items-center gap-2">
                          <input type="number" x-model.number="selected.priceMin" placeholder="От"
                                 class="w-1/2 p-1 border border-teal-400 rounded">
                          <input type="number" x-model.number="selected.priceMax" placeholder="До"
                                 class="w-1/2 p-1 border border-teal-400 rounded">
                      </div>
                  </div>

                  <!-- 4. Цвет -->
                  <div class="mb-4">
                      <h3 class="font-medium text-gray-700 mb-1">Цвет</h3>
                      <div class="flex flex-wrap gap-2">
                          <template x-for="color in colors" :key="color.value">
                              <span class="w-6 h-6 rounded-full border-2 cursor-pointer block"
                                    :style="`background-color:${color.hex}`"
                                    :class="selected.colors.includes(color.value) ? 'ring-2 ring-teal-500' : ''"
                                    @@click="
                                    selected.colors.includes(color.value)
                                    ? selected.colors=selected.colors.filter(c =>
                                  c !== color.value)
                                  : selected.colors.push(color.value)
                                  "
                                  >
                              </span>
                          </template>
                      </div>
                  </div>

                  <!-- 5. Сортировка -->
                  <div class="mb-4">
                      <h3 class="font-medium text-gray-700 mb-1">Сортировка</h3>
                      <select x-model="selected.sort" class="w-full border border-teal-400 rounded p-1">
                          <option value="">По умолчанию</option>
                          <option value="price-asc">Цена: наименьшая</option>
                          <option value="price-desc">Цена: наибольшая</option>
                          <option value="rating-desc">Рейтинг: сначала лучшие</option>
                          <option value="popularity-desc">Популярность</option>
                          <option value="discount-desc">Размер скидки</option>
                          <option value="newest">Новинки</option>
                      </select>
                  </div>

                  <!-- 6. Дополнительно -->
                  <div class="mb-4" x-data="{ openExtraMobile: false }">
                      <h3 @@click="openExtraMobile = !openExtraMobile"
                          class="font-medium text-gray-700 mb-1 flex justify-between cursor-pointer">
                          Дополнительно
                          <svg :class="{'rotate-180': openExtraMobile}"
                               class="w-5 h-5 transition-transform"
                               fill="currentColor"
                               viewBox="0 0 20 20">
                              <path fill-rule="evenodd"
                                    d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
                                    clip-rule="evenodd" />
                          </svg>
                      </h3>

                      <div x-show="openExtraMobile" x-transition class="pl-2 space-y-2">

                          <!-- Радиус колёс -->
                          <div>
                              <h4 class="font-medium text-gray-700">Радиус колёс</h4>
                              <template x-for="item in wheelSizes" :key="item">
                                  <label class="flex items-center gap-2 mb-1 cursor-pointer">
                                      <input type="checkbox" x-model="selected.wheelSizes" :value="item" class="accent-teal-600">
                                      <span x-text="item"></span>
                                  </label>
                              </template>
                          </div>

                          <!-- Размер рамы -->
                          <div>
                              <h4 class="font-medium text-gray-700">Размер рамы</h4>
                              <template x-for="item in frameSizes" :key="item">
                                  <label class="flex items-center gap-2 mb-1 cursor-pointer">
                                      <input type="checkbox" x-model="selected.frameSizes" :value="item" class="accent-teal-600">
                                      <span x-text="item"></span>
                                  </label>
                              </template>
                          </div>

                          <!-- Объём аккумулятора -->
                          <div>
                              <h4 class="font-medium text-gray-700">Объём аккумулятора</h4>
                              <template x-for="item in batteries" :key="item">
                                  <label class="flex items-center gap-2 mb-1 cursor-pointer">
                                      <input type="checkbox" x-model="selected.batteries" :value="item" class="accent-teal-600">
                                      <span x-text="item"></span>
                                  </label>
                              </template>
                          </div>

                          <!-- Тип тормоза -->
                          <div>
                              <h4 class="font-medium text-gray-700">Тип тормоза</h4>
                              <template x-for="item in brakes" :key="item">
                                  <label class="flex items-center gap-2 mb-1 cursor-pointer">
                                      <input type="checkbox" x-model="selected.brakes" :value="item" class="accent-teal-600">
                                      <span x-text="item"></span>
                                  </label>
                              </template>
                          </div>

                          <!-- Бренд -->
                          <div>
                              <h4 class="font-medium text-gray-700">Бренд / Страна</h4>
                              <template x-for="item in brands" :key="item.value">
                                  <label class="flex items-center gap-2 mb-1 cursor-pointer">
                                      <input type="checkbox" x-model="selected.brands" :value="item.value" class="accent-teal-600">
                                      <span x-text="item.label"></span>
                                  </label>
                              </template>
                          </div>

                      </div>
                  </div>

                  <!-- Кнопки -->
                  <div class="flex gap-2 mt-4">
                      <button @@click="applyFilters(); openFilters = false"
                              class="flex-1 bg-teal-600 text-white py-2 rounded hover:bg-teal-700 font-medium">
                          Применить
                      </button>
                      <button @@click="clearFilters()"
                              class="flex-1 border border-teal-600 text-teal-600 py-2 rounded hover:bg-teal-50">
                          Сбросить
                      </button>
                  </div>

              </div>
          </div>

          <main class="flex-grow container mx-auto mt-20">
              <div class="mb-6 flex flex-col gap-4 sm:mb-8 md:mb-12">
                  <div class="bg-white dark:bg-gray-800 sm:py-8 lg:py-4 container px-2 py-1">
                      <div class="max-w-screen-3xl px-2 py-4 md:px-8 mx-auto">

                          <!-- ОБЁРТКА ALPINE -->
                          <div x-data="filters()" class="min-h-screen">

                              <!-- H1 + Хлебные крошки + кнопка фильтра -->
                              <div class="mb-6 flex flex-col sm:flex-row items-start sm:items-center justify-between sm:gap-2 sm:mb-8 md:mb-12">
                                  <h1 class="text-2xl font-bold text-teal-800 lg:text-3xl dark:text-white">
                                      Katalog produktów
                                  </h1>

                                  <nav class="flex items-center justify-between w-full md:w-auto" aria-label="Breadcrumb">
                                      <ol class="inline-flex items-center space-x-1 md:space-x-2 rtl:space-x-reverse">
                                          <li class="inline-flex items-center">
                                              <a href="#"
                                                 class="inline-flex items-center text-sm font-medium text-teal-700 hover:text-red-700 dark:text-gray-400 dark:hover:text-white">
                                                  <svg class="w-3 h-3 me-2.5" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20">
                                                      <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z" />
                                                  </svg>
                                                  Dom
                                              </a>
                                              <svg class="rtl:rotate-180 w-3 h-3 text-gray-700 mx-1" fill="none" viewBox="0 0 6 10">
                                                  <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                        d="m1 9 4-4-4-4" />
                                              </svg>
                                          </li>
                                          <li aria-current="page">
                                              <div class="flex items-center">
                                                  <span class="ms-1 text-sm font-medium text-gray-500 md:ms-2 dark:text-gray-400">
                                                      Katalog produktów
                                                  </span>
                                              </div>
                                          </li>
                                      </ol>

                                      <!-- MOBILE FILTER BUTTON -->
                                      <div class="md:hidden flex" x-data>
                                          <button @@click="$store.ui.openFilters = !$store.ui.openFilters"
                                                  class="flex-1 border border-teal-400 text-teal-400 p-2 rounded hover:bg-teal-50 flex items-center justify-center gap-1 text-sm transition">

                                              <!-- Иконка фильтра -->
                                              <svg x-show="!$store.ui.openFilters"
                                                   x-cloak
                                                   x-transition.opacity
                                                   class="w-[24px] h-[24px] text-teal-800 dark:text-white"
                                                   xmlns="http://www.w3.org/2000/svg"
                                                   fill="none"
                                                   viewBox="0 0 24 24"
                                                   stroke-width="1.7"
                                                   stroke="currentColor">
                                                  <path stroke-linecap="round"
                                                        d="M18.796 4H5.204a1 1 0 0 0-.753 1.659l5.302 6.058a1 1 0 0 1 .247.659v4.874a.5.5 0 0 0 .2.4l3 2.25a.5.5 0 0 0 .8-.4v-7.124a1 1 0 0 1 .247-.659l5.302-6.059c.566-.646.106-1.658-.753-1.658Z" />
                                              </svg>

                                              <!-- Иконка крестика -->
                                              <svg x-show="$store.ui.openFilters"
                                                   x-cloak
                                                   x-transition.opacity
                                                   class="w-[26px] h-[26px] text-teal-800 dark:text-white"
                                                   xmlns="http://www.w3.org/2000/svg"
                                                   fill="none"
                                                   viewBox="0 0 24 24"
                                                   stroke-width="2"
                                                   stroke="currentColor">
                                                  <path stroke-linecap="round" stroke-linejoin="round"
                                                        d="M6 18L18 6M6 6l12 12" />
                                              </svg>

                                          </button>
                                      </div>
                                  </nav>
                              </div>

                              <!-- MOBILE FILTER OVERLAY -->
                              <div x-show=""
                                   @@click.self="$store.ui.openFilters = false"
                                   ...>

                                  <div x-show="$store.ui.openFilters" x-transition.opacity @@click.self="$store.ui.openFilters = false" class="fixed inset-0 bg-black/50 z-50 md:hidden">
