          <!-- темная тема -->
          <script>
              function themeSwitcher() {
                  return {
                      isDark:
                          localStorage.getItem("theme") === "dark" ||
                          (!("theme" in localStorage) &&
                              window.matchMedia("(prefers-color-scheme: dark)").matches),

                      toggleTheme() {
                          this.isDark = !this.isDark;
                          if (this.isDark) {
                              document.documentElement.classList.add("dark");
                              localStorage.setItem("theme", "dark");
                          } else {
                              document.documentElement.classList.remove("dark");
                              localStorage.setItem("theme", "light");
                          }
                      },

                      init() {
                          if (this.isDark) {
                              document.documentElement.classList.add("dark");
                          } else {
                              document.documentElement.classList.remove("dark");
                          }
                      },
                  };
              }
          </script>


          <!-- модальное окно -->
          <script>
              function imageModal() {
                  return {
                      images: [
                          "/assets/images/cycling-hat-bottle-bench.jpg",
                          "/assets/images/biking-leisure-black-sky-riding.jpg",
                          "/assets/images/cool-bicycle-outdoors.jpg",
                          "/assets/images/silhouettes-riding-bicycles-scooters-dusk-generated-by-ai.jpg",
                      ],
                      currentIndex: 0,
                      isOpen: false,
                      intervalId: null,

                      init() {
                          this.startAutoSlide();
                      },

                      setImage(index) {
                          this.currentIndex = index;
                      },

                      handleMainImageClick() {
                          if (window.innerWidth >= 768) {
                              this.isOpen = true;
                              this.stopAutoSlide();
                          }
                      },

                      openModal(index) {
                          this.currentIndex = index;
                          this.isOpen = true;
                          this.stopAutoSlide();
                      },

                      closeModal() {
                          this.isOpen = false;
                          this.startAutoSlide();
                      },

                      nextImage() {
                          this.currentIndex = (this.currentIndex + 1) % this.images.length;
                      },

                      prevImage() {
                          this.currentIndex =
                              (this.currentIndex - 1 + this.images.length) % this.images.length;
                      },

                      startAutoSlide() {
                          this.intervalId = setInterval(() => {
                              this.nextImage();
                          }, 5000);
                      },

                      stopAutoSlide() {
                          if (this.intervalId) {
                              clearInterval(this.intervalId);
                              this.intervalId = null;
                          }
                      },
                  };
              }
          </script>
