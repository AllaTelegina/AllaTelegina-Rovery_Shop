                                  id="default-styled-tab" data-tabs-toggle="#default-styled-tab-content"
                                  data-tabs-active-classes="text-red-700 hover:text-red-600 dark:text-purple-700 dark:hover:text-purple-500 border-red-600 dark:border-purple-500"
