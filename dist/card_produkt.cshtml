@using Backend_asp.net.Models.Class_for_views
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@model ProductsGeneral
<html lang="pl" class="h-full">
    <head>
        <meta charset="UTF-8">
        <title>card_produkt</title>
        <link href="output.css" rel="stylesheet">
        <script src="https://cdn.tailwindcss.com"></script>

        <!-- Alpine.js (defer - скрипт ждёт загрузки DOM) -->
        <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>

        <!-- Flowbite JS (версия 2.3.0) -->
        <script defer src="https://unpkg.com/flowbite@2.3.0/dist/flowbite.min.js"></script>

        <!-- основной JS -->

        <script type="module" defer src="./main.js"></script>
    </head>
    <body class="flex flex-col min-h-screen">

        <!-- Модальное окно вход -->
        <div id="authentication-modal" tabindex="-1" aria-hidden="true" class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 inset-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full">
            <div class="relative p-4 w-full max-w-md max-h-full">
                <!-- Modal content -->
                <div class="relative bg-white rounded-lg shadow-sm dark:bg-gray-700">
                    <!-- Modal header -->
                    <div class="flex items-center justify-between p-4 md:p-5 border-b rounded-t dark:border-gray-600 border-gray-200">
                        <h3 class="text-xl font-semibold text-gray-900 dark:text-white">
                                Zaloguj się na swoje konto osobiste
                        </h3>
                        <button type="button"
                            class="end-2.5 text-gray-400 bg-transparent hover:bg-gray-200 hover:text-gray-900 rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center dark:hover:bg-gray-600 dark:hover:text-white"
                            data-modal-hide="authentication-modal">
                            <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none"
                                viewBox="0 0 14 14">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
                                        stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
                            </svg>
                            <span class="sr-only">Close modal</span>
                        </button>
                    </div>
                    <!-- Modal body -->
                    <div class="p-4 md:p-5">
                        <div
                            @@click="mode = 'login'"
                            x-show="mode === 'login' || window.innerWidth >= 640"
                            x-cloak
                            :class="mode === 'login' ? 'ring-2 ring-teal-200' : ''"
                            class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow transition-all">

                            <form class="space-y-4" action="#">
                                <div>
                                    <label for="email" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Twój
                                        e-mail
                                    </label>
                                    <input type="email" name="email" id="email" class="border border-teal-300 text-gray-900 text-sm rounded-lg focus:ring-teal-700 focus:border-teal-500 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white"
                                        placeholder="name@company.com" required/>
                                </div>
                                <div>
                                    <label for="password" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Twoje
                                        hasło
                                    </label>
                                    <input type="password" name="password" id="password" placeholder="••••••••"
                                        class="border border-teal-300 text-gray-900 text-sm rounded-lg focus:ring-teal-700 focus:border-teal-500 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white"
                                        required/>
                                </div>
                                <div class="flex justify-between">
                                    <div class="flex items-start">

                                        <div x-data="{ checked: false }"
                                            class="flex items-center text-sm cursor-pointer space-x-2">
                                            <!-- Кастомный чекбокс -->
                                            <div @@click="checked = !checked"
                                                class="w-5 h-5 border border-gray-400 rounded flex items-center justify-center"
                                                :class="{ 'bg-teal-500 border-teal-500': checked }">
                                                <!-- Галочка -->
                                                <svg x-show="checked" xmlns="http://www.w3.org/2000/svg"
                                                    class="w-3 h-3 text-white" fill="none"
                                                    viewBox="0 0 24 24"
                                                    stroke="currentColor" stroke-width="4">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        d="M5 13l4 4L19 7"/>
                                                </svg>
                                            </div>

                                            <!-- Текст и скрытый checkbox для форм -->
                                            <label for="remember" class="ms-2 text-sm  text-gray-900 dark:text-gray-300">
                                                <input type="checkbox" id="terms" name="terms" x-model="checked" class="hidden" required/>
                                                Pamiętaj mnie
                                            </label>
                                        </div>

                                    </div>
                                    <a href="/dist/forgot_password.html" class="text-sm font-medium hover:text-teal-500 text-red-700 hover:underline dark:text-blue-500">Zapomniałem
                                        hasła?
                                    </a>
                                </div>

                                <div class="mt-6">
                                    <div class="relative">
                                        <div class="absolute inset-0 flex items-center">
                                            <div class="w-full border-t border-teal-500"></div>
                                        </div>
                                        <div class="relative flex justify-center text-sm">
                                            <span class="bg-white dark:bg-teal-700 px-2 text-gray-500 dark:text-white">Login using</span>
                                        </div>
                                    </div>
                                    <button class="inline-flex w-full items-center justify-center rounded-md border border-teal-700 bg-white dark:bg-gray-700 px-4 py-2 text-sm font-medium text-teal-700 hover:text-white dark:text-white shadow-sm hover:bg-teal-400 dark:hover:bg-gray-600 disabled:cursor-wait disabled:opacity-50">
                                        <span class="sr-only">Sign in with Google</span>
                                        <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"
                                            aria-hidden="true">
                                            <clipPath id="p.0">
                                                <path d="m0 0l20.0 0l0 20.0l-20.0 0l0 -20.0z" clip-rule="nonzero"></path>
                                            </clipPath>
                                            <g clip-path="url(#p.0)">
                                                <path fill="currentColor" fill-opacity="0.0" d="m0 0l20.0 0l0 20.0l-20.0 0z" fill-rule="evenodd"></path>
                                                <path fill="currentColor" d="m19.850197 8.270351c0.8574047 4.880001 -1.987587 9.65214 -6.6881847 11.218641c-4.700598 1.5665016 -9.83958 -0.5449295
                                                    -12.08104 -4.963685c-2.2414603 -4.4187555 -0.909603 -9.81259 3.1310139 -12.6801605c4.040616 -2.867571 9.571754 -2.3443127 13.002944 1.2301085l-2.8127813 2.7000687l0 0c-2.0935059 -2.1808972 -5.468274 -2.500158 -7.933616 -0.75053835c-2.4653416 1.74962 -3.277961 5.040613 -1.9103565 7.7366734c1.3676047 2.6960592 4.5031037 3.9843292 7.3711267 3.0285425c2.868022 -0.95578575 4.6038647 -3.8674583 4.0807285 -6.844941z" fill-rule="evenodd"></path>
                                                <path fill="currentColor"d="m10.000263 8.268785l9.847767 0l0 3.496233l-9.847767 0z"fill-rule="evenodd"></path>
                                            </g>
                                        </svg>
                                    </button>
                                </div>
                                <button type="submit" class="w-full uppercase text-white hover:bg-red-600 bg-teal-600 focus:ring-4 focus:outline-none focus:ring-teal-500 font-medium rounded-lg text-sm px-5 py-3.5 text-center dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800">
                                    wejście
                                </button>
                                <div class="text-sm font-medium text-gray-500 dark:text-gray-300">
                                    Nie jesteś zarejestrowany?
                                    <a href="/dist/registration.html" class="hover:text-teal-800 text-red-700 hover:underline dark:text-blue-500">Utwórz
                                        konto
                                    </a>
                                </div>
                            </form>

                        </div>
                    </div>
                </div>
            </div>
        </div>


        <!-- Модальное окно поиска -->
        <div id="search-modal" tabindex="-1" aria-hidden="true"
            class="hidden fixed inset-0 z-50 w-full p-4 overflow-x-hidden overflow-y-auto flex items-start justify-center pt-20 sm:pt-32">

            <!-- Контейнер формы -->
            <div class="relative w-full max-w-xl sm:max-w-2xl lg:max-w-7xl">
                <div class="relative bg-gray-800/10 rounded-xl shadow dark:bg-gray-700 p-6 lg:p-10 min-h-[280px] lg:min-h-[360px]">
                    <!-- Кнопка закрытия -->
                    <button type="button" class="absolute top-2 right-2 text-white bg-transparent hover:bg-gray-200 hover:text-teal-600 rounded-lg text-sm w-8 h-8 flex items-center justify-center dark:hover:bg-gray-600 dark:hover:text-white"
                            data-modal-hide="search-modal">
                        <svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1l6 6m0 0l6 6M7 7l6-6M7 7L1 13"/>
                        </svg>
                        <span class="sr-only">Закрыть</span>
                    </button>

                    <!-- Форма поиска -->
                    <form class="mt-6">
                        <div class="relative w-full">
                            <input placeholder="e.g. Blog" class="rounded-full w-full h-16 bg-white py-2 pl-8 pr-32 outline-none border-2 border-gray-200 shadow-md hover:outline-none focus:ring-teal-200 focus:border-teal-200 dark:bg-gray-600 dark:border-gray-500 dark:text-white"
                                type="text" name="query" id="query">

                            <button type="submit" class="absolute inline-flex items-center h-10 px-4 py-2 text-sm text-white transition duration-150 ease-in-out rounded-full right-3 top-3 bg-teal-600 sm:px-6 sm:text-base sm:font-medium hover:bg-teal-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-teal-500">
                                <svg class="-ml-0.5 sm:-ml-1 mr-2 w-4 h-4 sm:h-5 sm:w-5"
                                    xmlns="http://www.w3.org/2000/svg" fill="none"
                                    viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                                </svg>
                                Search
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <main class="flex-grow container mx-auto mt-20">

            <div class="mb-6 flex flex-col gap-4 sm:mb-8 md:mb-12">
                <div class="bg-white dark:bg-gray-800 sm:py-8 lg:py-4 container px-2 py-1 ">
                    <div class="max-w-screen-3xl px-2 py-4 md:px-8 mx-auto">

                        <!-- H! + Хлебные крошки -->
                        <div class="mb-6 flex flex-col sm:flex-row items-start sm:items-center justify-between sm:gap-2 sm:mb-8 md:mb-12">
                            <h1 class="text-2xl font-bold text-teal-800 lg:text-3xl dark:text-white">O produkcie</h1>
                            <!-- Хлебные крошки -->
                            <nav class="flex" aria-label="Breadcrumb">
                                <ol class="inline-flex items-center space-x-1 md:space-x-2 rtl:space-x-reverse">
                                    <li class="inline-flex items-center">
                                        <a href="#" class="inline-flex items-center text-sm font-medium text-teal-700 hover:text-red-700 dark:text-gray-400 dark:hover:text-white">
                                            <svg class="w-3 h-3 me-2.5" aria-hidden="true" fill="currentColor"
                                                    viewBox="0 0 20 20">
                                                <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
                                            </svg>
                                            Dom
                                        </a>
                                        <svg class="rtl:rotate-180 w-3 h-3 text-gray-700 mx-1" fill="none" viewBox="0 0 6 10">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
                                        </svg>
                                    </li>
                                    <li class="inline-flex items-center">
                                        <a href="#"
                                            class="inline-flex items-center text-sm font-medium text-teal-700 hover:text-red-700 dark:text-gray-400 dark:hover:text-white">
                                            Katalog rowerów
                                        </a>
                                    </li>
                                    <li aria-current="page">
                                        <div class="flex items-center">
                                            <svg class="rtl:rotate-180 w-3 h-3 text-gray-400 mx-1" fill="none" viewBox="0 0 6 10">
                                                <path stroke="currentColor" stroke-linecap="round"
                                                    stroke-linejoin="round" stroke-width="2"
                                                    d="m1 9 4-4-4-4"/>
                                            </svg>
                                            <span class="ms-1 text-sm font-medium text-gray-500 md:ms-2 dark:text-gray-400">O produkcie</span>
                                        </div>
                                    </li>
                                </ol>
                            </nav>
                        </div>

                        <div class="container mx-auto px-2 py-4">

                            <!-- карточка продукта -->
                            <div class="flex flex-wrap -mx-4">
                                <!-- Product Images -->
                                <div class="w-full md:w-1/2 px-4 mb-8">
                                    <div x-data="imageModal()" x-init="init()" @@keydown.escape.window="closeModal" class="relative">
                                        <img :src="images[currentIndex]"
                                            @@click="handleMainImageClick"
                                            @@load="onImageLoad"
                                            class="w-full h-auto rounded-lg shadow-md mb-4 transition-opacity duration-700 ease-in-out"
                                            :class="{ 'opacity-0': isFading, 'opacity-100': !isFading }"
                                            alt="Product"
                                            id="mainImage">

                                        <div class="flex gap-4 py-4 justify-center overflow-x-auto">
                                            <template x-for="(img, index) in images" :key="index">
                                                <img :src="img"
                                                    @@click="setImage(index)"
                                                    class="size-16 sm:size-20 object-cover rounded-md cursor-pointer opacity-60 hover:opacity-100 transition duration-300"
                                                    :alt="'Thumbnail ' + (index + 1)">
                                            </template>
                                        </div>

                                        <!-- Модальное окно -->
                                        <div x-show="isOpen"
                                            x-transition
                                            class="fixed inset-0 bg-black bg-opacity-80 flex items-center justify-center z-50"
                                            @@click.self="closeModal">
                                            <div class="relative w-full max-w-screen-xl px-4">

                                                <!-- Закрыть (крестик) -->
                                                <button @@click="closeModal" class="fixed top-4 right-4 text-white text-3xl font-bold z-50"> &times;</button>

                                                <!-- Левая стрелка -->
                                                <button @@click="prevImage"
                                                    class="fixed left-4 top-1/2 -translate-y-1/2 bg-black/30 text-white p-2 rounded-full
                                                    hover:bg-black/60 transition"
                                                    x-show="images.length > 1">
                                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                        <path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
                                                    </svg>
                                                </button>

                                                <!-- Изображение -->
                                                <img :src="images[currentIndex]"
                                                    class="max-h-[120vh] w-auto max-w-full lg:max-w-7xl mx-auto rounded shadow-lg"
                                                    alt="Preview">

                                                <!-- Правая стрелка -->
                                                <button @@click="nextImage"
                                                    class="fixed right-4 top-1/2 -translate-y-1/2 bg-black/30 text-white p-2 rounded-full
                                                    hover:bg-black/60 transition"
                                                    x-show="images.length > 1">
                                                    <svg class="w-5 h-5" fill="none" stroke="currentColor"
                                                        stroke-width="2" viewBox="0 0 24 24">
                                                        <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
                                                    </svg>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Product Details -->
                                <div class="w-full md:w-1/2 px-4">
                                        <h2 class="text-3xl font-bold mb-2">@Model.ProductFromAdmin.Name</h2>
                                <p class="text-gray-600 mb-4">@Model.ProductFromAdmin.SkuNumber</p>
                                    <div class="mb-4">
                                        <span class="text-2xl font-bold mr-2">$@Model.ProductFromAdmin.Prise</span>
                                        <span class="text-gray-500 line-through">$@Model.ProductFromAdmin.Lastprise</span>
                                    </div>
                                    <div class="flex items-center mb-4">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                            fill="currentColor"
                                            class="size-6 text-teal-400">
                                            <path fill-rule="evenodd"
                                                d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z"
                                                clip-rule="evenodd"/>
                                        </svg>
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                            fill="currentColor"
                                            class="size-6 text-teal-400">
                                            <path fill-rule="evenodd"
                                                d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z"
                                                clip-rule="evenodd"/>
                                        </svg>
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                            fill="currentColor"
                                            class="size-6 text-teal-400">
                                            <path fill-rule="evenodd"
                                                d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z"
                                                clip-rule="evenodd"/>
                                        </svg>
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                            fill="currentColor"
                                            class="size-6 text-teal-400">
                                            <path fill-rule="evenodd"
                                                d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z"
                                                clip-rule="evenodd"/>
                                        </svg>
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                            fill="currentColor"
                                            class="size-6 text-gray-400">
                                            <path fill-rule="evenodd"
                                                d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z"
                                                clip-rule="evenodd"/>
                                        </svg>
                                        <span class="ml-2 text-gray-600">@Model.ProductFromAdmin.Rating (120 reviews)</span>
                                    </div>
                                    <p class="text-gray-700 mb-6">@Model.ProductFromAdmin.BriefDiscription</p>

                                    <div class="mb-6">
                                        <h3 class="text-lg font-semibold mb-2">Color:</h3>
                                        <div class="flex space-x-2">
                                            <button
                                                class="w-8 h-8 bg-black rounded-full focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-black"></button>
                                            <button
                                                class="w-8 h-8 bg-gray-300 rounded-full focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-300"></button>
                                            <button
                                                class="w-8 h-8 bg-blue-500 rounded-full focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500"></button>
                                            <button
                                                class="w-8 h-8 bg-green-400 rounded-full focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-400"></button>

                                        </div>
                                    </div>

                                    <div class="mb-6">
                                        <label for="quantity"
                                            class="block text-sm font-medium text-gray-700 mb-1">Quantity:</label>
                                        <input type="number" id="quantity" name="quantity" min="1" value="1"
                                            class="w-12 text-center rounded-md border-gray-300  shadow-sm focus:border-indigo-300 focus:ring focus:ring-indigo-200 focus:ring-opacity-50">
                                    </div>

                                    <div class="flex space-x-4 mb-6">

                                        <div x-data="{ inCart: false }">
                                            <button
                                                type="button"
                                                @@click="inCart = !inCart"
                                                :aria-pressed="inCart.toString()"
                                                :class="[
                                                'inline-flex items-center border-2 border-red-600 gap-2 rounded-lg px-5 py-2 text-xs lg:px-6 lg:py-2.5 lg:text-sm uppercase transition-colors duration-200 focus:outline-none  active:scale-95',
                                                inCart
                                                ? 'bg-red-600 text-white hover:bg-red-500'
                                                : 'text-red-600 hover:bg-teal-400 hover:border-teal-500 hover:text-white'
                                                ]">
                                                <!-- Состояние до добавления -->
                                                <template x-if="!inCart">
                                                        <span>Do&nbsp;koszyka</span>
                                                </template>
                                                <!-- Состояние после добавления -->
                                                <template x-if="inCart">
                                                    <span class="inline-flex items-center gap-2">
                                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none"
                                                            viewBox="0 0 24 24" stroke-width="1.5"
                                                            stroke="currentColor" class="size-5">
                                                            <path stroke-linecap="round" stroke-linejoin="round"
